---
import '../styles/globals.css';
import HreflangTags from '../components/i18n/HreflangTags.astro';
import { getLangFromUrl } from '../i18n/utils';

interface Props {
    title?: string;
    description?: string;
    ogImage?: string;
    robots?: string;
    jsonLd?: Record<string, any>;
    keywords?: string[];
    pubDate?: Date;
    updatedDate?: Date;
}

const lang = getLangFromUrl(Astro.url);

const {
    title = "GetMediaTools - Social Media Guides & Creator Tips",
    description = "Expert guides, tips, and tutorials for social media content creators. TikTok, Instagram, Twitter, Facebook and more.",
    ogImage = "/icon-512.png",
    robots = "index, follow",
    jsonLd,
    pubDate,
    updatedDate,
} = Astro.props;

// All supported locales for og:locale:alternate tags
const ALL_LOCALES = ['en', 'es', 'tr', 'pt', 'fr', 'de', 'ja', 'ko', 'ar', 'hi'];
const OG_LOCALE_MAP: Record<string, string> = {
    en: 'en_US', es: 'es_ES', tr: 'tr_TR', pt: 'pt_BR', fr: 'fr_FR',
    de: 'de_DE', ja: 'ja_JP', ko: 'ko_KR', ar: 'ar_SA', hi: 'hi_IN',
};

// Ensure canonical URLs always have trailing slashes (Cloudflare Pages enforces them)
const pathname = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : Astro.url.pathname + '/';
const canonicalUrl = `https://getmediatools.com${pathname}`;
const fullOgImage = ogImage.startsWith('http') ? ogImage : `https://getmediatools.com${ogImage}`;

// Generate BreadcrumbList schema from URL path
const allSegments = pathname.split('/').filter(Boolean);
const NON_DEFAULT_LOCALES = ['es', 'tr', 'pt', 'fr', 'de', 'ja', 'ko', 'ar', 'hi'];
// Skip locale prefix from breadcrumb items
const contentSegments = allSegments.length > 0 && NON_DEFAULT_LOCALES.includes(allSegments[0])
    ? allSegments.slice(1)
    : allSegments;
const localeHome = lang === 'en' ? '/' : `/${lang}/`;

const BREADCRUMB_LABELS: Record<string, string> = {
    'blog': 'Blog',
    'creator-growth': 'Creator Growth',
    'privacy-security': 'Privacy & Security',
};

const breadcrumbItems = [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": `https://getmediatools.com${localeHome}` }
];

let breadcrumbPath = lang === 'en' ? '' : `/${lang}`;
contentSegments.forEach((segment, index) => {
    breadcrumbPath += `/${segment}`;
    breadcrumbItems.push({
        "@type": "ListItem",
        "position": index + 2,
        "name": BREADCRUMB_LABELS[segment] || segment.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' '),
        "item": `https://getmediatools.com${breadcrumbPath}/`
    });
});

const breadcrumbSchema = contentSegments.length > 0 ? {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": breadcrumbItems
} : null;

// WebSite schema — tells Google to show branded name in SERP breadcrumbs
// Skip if the page already provides its own jsonLd containing a WebSite type (e.g., homepage)
const isHomepage = contentSegments.length === 0;
const jsonLdHasWebSite = jsonLd && (
    jsonLd['@type'] === 'WebSite' ||
    (jsonLd['@graph'] && Array.isArray(jsonLd['@graph']) && jsonLd['@graph'].some((item: any) => item['@type'] === 'WebSite'))
);
const websiteSchema = (isHomepage && !jsonLdHasWebSite) ? {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "GetMediaTools",
    "alternateName": "MediaTools",
    "url": "https://getmediatools.com/"
} : null;
---

<!doctype html>
<html lang={lang}>
    <head>
        <meta charset="UTF-8" />
        <HreflangTags />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />
        <meta name="robots" content={robots} />
        <meta name="author" content="MediaTools" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="manifest" href="/manifest.json" />
        <meta name="theme-color" content="#7c3aed" />
        
        <!-- SEO -->
        <link rel="canonical" href={canonicalUrl} />
        <meta name="yandex-verification" content="cdcc6f25a321137f" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:type" content={pubDate ? 'article' : 'website'} />
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:image" content={fullOgImage} />
        <meta property="og:site_name" content="GetMediaTools" />
        <meta property="og:locale" content={OG_LOCALE_MAP[lang] || 'en_US'} />
        {ALL_LOCALES.filter(l => l !== lang).map(l => (
            <meta property="og:locale:alternate" content={OG_LOCALE_MAP[l]} />
        ))}
        {pubDate && (
            <meta property="article:published_time" content={pubDate.toISOString()} />
        )}
        {(updatedDate || pubDate) && (
            <meta property="article:modified_time" content={(updatedDate || pubDate)!.toISOString()} />
        )}
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={fullOgImage} />

        <title>{title}</title>

        <!-- JSON-LD Structured Data -->
        {jsonLd && (
            <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
        )}
        {breadcrumbSchema && (
            <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
        )}
        {websiteSchema && (
            <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
        )}
        
        <!-- Google AdSense -->
        <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3097071261671376" crossorigin="anonymous"></script>
    </head>
    <body class="min-h-screen bg-background">
        <slot />

        <!-- Deferred analytics loading (kept out of critical render path for mobile CWV) -->
        <script is:inline>
            (() => {
                const onIdle = (cb, timeout = 3500) => {
                    if ('requestIdleCallback' in window) {
                        window.requestIdleCallback(cb, { timeout });
                        return;
                    }
                    window.setTimeout(cb, Math.min(timeout, 2000));
                };

                const onLoad = (cb) => {
                    if (document.readyState === 'complete') {
                        cb();
                        return;
                    }
                    window.addEventListener('load', cb, { once: true });
                };

                const loadGoogleAnalytics = () => {
                    if (window.__gaLoaded) return;
                    window.__gaLoaded = true;

                    window.dataLayer = window.dataLayer || [];
                    window.gtag = window.gtag || function () {
                        window.dataLayer.push(arguments);
                    };

                    window.gtag('js', new Date());
                    window.gtag('config', 'G-7GYZ72XSW7', {
                        anonymize_ip: true,
                        transport_type: 'beacon',
                    });

                    const gaScript = document.createElement('script');
                    gaScript.async = true;
                    gaScript.src = 'https://www.googletagmanager.com/gtag/js?id=G-7GYZ72XSW7';
                    document.head.appendChild(gaScript);
                };

                const loadYandexMetrika = () => {
                    if (window.__ymLoaded) return;
                    window.__ymLoaded = true;

                    (function (m, e, t, r, i, k, a) {
                        m[i] =
                            m[i] ||
                            function () {
                                (m[i].a = m[i].a || []).push(arguments);
                            };
                        m[i].l = 1 * new Date();
                        k = e.createElement(t);
                        a = e.getElementsByTagName(t)[0];
                        k.async = 1;
                        k.src = r;
                        a.parentNode.insertBefore(k, a);
                    })(window, document, 'script', 'https://mc.yandex.ru/metrika/tag.js?id=107148029', 'ym');

                    window.ym(107148029, 'init', {
                        ssr: true,
                        webvisor: false,
                        clickmap: false,
                        ecommerce: 'dataLayer',
                        referrer: document.referrer,
                        url: location.href,
                        accurateTrackBounce: true,
                        trackLinks: true,
                    });
                };

                onLoad(() => {
                    onIdle(() => {
                        loadGoogleAnalytics();
                        loadYandexMetrika();
                    });
                });
            })();
        </script>
        <noscript><div><img src="https://mc.yandex.ru/watch/107148029" style="position:absolute; left:-9999px;" alt="" role="presentation" /></div></noscript>
    </body>
</html>

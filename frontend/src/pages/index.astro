---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer.astro';
import { ui } from '../i18n/ui';

const lang = 'en';

const jsonLd = {
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "WebSite",
            "name": "MediaTools",
            "url": "https://getmediatools.com",
            "description": "Free online tools to download videos from TikTok, Twitter, and Facebook. Extract audio to MP3 and grab thumbnails."
        },
        {
            "@type": "Organization",
            "name": "MediaTools",
            "url": "https://getmediatools.com",
            "logo": "https://getmediatools.com/icon-512.png",
            "description": "Free online tools for downloading videos, extracting audio, and grabbing thumbnails from social media platforms.",
            "sameAs": []
        }
    ]
};
---

<Layout 
    title={ui.en["index.meta.title"]}
    description={ui.en["index.meta.desc"]}
    jsonLd={jsonLd}
>
    <Navbar client:idle currentPage="home" lang={lang as keyof typeof ui} />
    
    <!-- Enhanced Hero Section -->
    <div class="w-full bg-[#1A1A2E] text-white pt-24 pb-32 px-4 relative overflow-hidden">
        <!-- Glow Effect Behind Text -->
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-3xl h-64 bg-[#405EDB] rounded-full mix-blend-screen filter blur-[100px] opacity-20"></div>
        
        <div class="container mx-auto max-w-4xl text-center relative z-10">
            <div class="mb-8">
                <span class="inline-block bg-[#405EDB]/20 text-[#8DA0FF] border border-[#405EDB]/30 text-xs font-bold px-4 py-1.5 rounded-full uppercase tracking-wider backdrop-blur-sm">
                    Ultimate Media Toolkit
                </span>
            </div>
            <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight mb-8 leading-[1.1] text-white">
                {ui.en["index.hero.title"]} <br class="hidden sm:block" />
                <span class="text-[#405EDB]">{ui.en["index.hero.highlight"]}</span>
            </h1>
            <p class="text-lg md:text-xl text-gray-300 max-w-2xl mx-auto leading-relaxed">
                {ui.en["index.hero.desc"]}
            </p>
        </div>
    </div>

    <!-- Main Content Area -->
    <main class="container mx-auto px-4 -mt-16 pb-24 relative z-20">

        <!-- Tools Grid -->
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 max-w-5xl mx-auto">
            
            <!-- TikTok Downloader -->
            <a href="/tiktok-downloader/" class="group block p-8 rounded-2xl bg-[#F4F7FB] dark:bg-slate-800 border border-transparent hover:bg-white dark:hover:bg-slate-700 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                <div class="w-14 h-14 rounded-xl bg-black flex items-center justify-center mb-6 relative overflow-hidden shadow-sm">
                    <svg class="w-8 h-8 absolute" style="left: 13px; top: 12px;" viewBox="0 0 24 24" fill="#00f2ea">
                        <path d="M19.321 5.562a5.124 5.124 0 0 1-.443-.258 6.228 6.228 0 0 1-1.137-.966c-.849-.849-1.18-1.69-1.333-2.338h.003c-.11-.467-.073-.77-.066-.77h-3.547v13.473c0 .181 0 .359-.008.534a3.874 3.874 0 0 1-.022.287l-.001.021v.011a2.9 2.9 0 0 1-.881 1.838 2.87 2.87 0 0 1-2.028.824 2.9 2.9 0 0 1-2.9-2.9 2.9 2.9 0 0 1 2.9-2.9c.304 0 .596.049.868.138v-3.6a6.391 6.391 0 0 0-.868-.059 6.45 6.45 0 0 0-4.568 1.868A6.387 6.387 0 0 0 3.4 15.9a6.4 6.4 0 0 0 .389 2.187 6.452 6.452 0 0 0 1.5 2.1 6.437 6.437 0 0 0 4.568 1.88 6.45 6.45 0 0 0 4.568-1.88 6.394 6.394 0 0 0 1.89-4.568V9.55a9.372 9.372 0 0 0 5.49 1.77V7.77s-2.485.097-4.484-2.208z"/>
                    </svg>
                    <svg class="w-8 h-8 absolute" style="left: 15px; top: 14px;" viewBox="0 0 24 24" fill="#ff0050">
                        <path d="M19.321 5.562a5.124 5.124 0 0 1-.443-.258 6.228 6.228 0 0 1-1.137-.966c-.849-.849-1.18-1.69-1.333-2.338h.003c-.11-.467-.073-.77-.066-.77h-3.547v13.473c0 .181 0 .359-.008.534a3.874 3.874 0 0 1-.022.287l-.001.021v.011a2.9 2.9 0 0 1-.881 1.838 2.87 2.87 0 0 1-2.028.824 2.9 2.9 0 0 1-2.9-2.9 2.9 2.9 0 0 1 2.9-2.9c.304 0 .596.049.868.138v-3.6a6.391 6.391 0 0 0-.868-.059 6.45 6.45 0 0 0-4.568 1.868A6.387 6.387 0 0 0 3.4 15.9a6.4 6.4 0 0 0 .389 2.187 6.452 6.452 0 0 0 1.5 2.1 6.437 6.437 0 0 0 4.568 1.88 6.45 6.45 0 0 0 4.568-1.88 6.394 6.394 0 0 0 1.89-4.568V9.55a9.372 9.372 0 0 0 5.49 1.77V7.77s-2.485.097-4.484-2.208z"/>
                    </svg>
                    <svg class="w-8 h-8 relative z-10" viewBox="0 0 24 24" fill="white">
                        <path d="M19.321 5.562a5.124 5.124 0 0 1-.443-.258 6.228 6.228 0 0 1-1.137-.966c-.849-.849-1.18-1.69-1.333-2.338h.003c-.11-.467-.073-.77-.066-.77h-3.547v13.473c0 .181 0 .359-.008.534a3.874 3.874 0 0 1-.022.287l-.001.021v.011a2.9 2.9 0 0 1-.881 1.838 2.87 2.87 0 0 1-2.028.824 2.9 2.9 0 0 1-2.9-2.9 2.9 2.9 0 0 1 2.9-2.9c.304 0 .596.049.868.138v-3.6a6.391 6.391 0 0 0-.868-.059 6.45 6.45 0 0 0-4.568 1.868A6.387 6.387 0 0 0 3.4 15.9a6.4 6.4 0 0 0 .389 2.187 6.452 6.452 0 0 0 1.5 2.1 6.437 6.437 0 0 0 4.568 1.88 6.45 6.45 0 0 0 4.568-1.88 6.394 6.394 0 0 0 1.89-4.568V9.55a9.372 9.372 0 0 0 5.49 1.77V7.77s-2.485.097-4.484-2.208z"/>
                    </svg>
                </div>
                <h2 class="font-bold text-xl mb-2 text-slate-900 dark:text-white group-hover:text-[#405EDB] transition-colors">{ui.en["index.tools.tt.title"]}</h2>
                <p class="text-[16px] text-slate-600 dark:text-slate-400 leading-relaxed">{ui.en["index.tools.tt.desc"]}</p>
            </a>

            <!-- Twitter/X Downloader -->
            <a href="/twitter-downloader/" class="group block p-8 rounded-2xl bg-[#F4F7FB] dark:bg-slate-800 border border-transparent hover:bg-white dark:hover:bg-slate-700 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                <div class="w-14 h-14 rounded-xl bg-black flex items-center justify-center mb-6 shadow-sm">
                    <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                    </svg>
                </div>
                <h2 class="font-bold text-xl mb-2 text-slate-900 dark:text-white group-hover:text-[#405EDB] transition-colors">{ui.en["index.tools.tw.title"]}</h2>
                <p class="text-[16px] text-slate-600 dark:text-slate-400 leading-relaxed">{ui.en["index.tools.tw.desc"]}</p>
            </a>

            <!-- Facebook Downloader -->
            <a href="/facebook-downloader/" class="group block p-8 rounded-2xl bg-[#F4F7FB] dark:bg-slate-800 border border-transparent hover:bg-white dark:hover:bg-slate-700 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                <div class="w-14 h-14 rounded-xl bg-blue-600 flex items-center justify-center mb-6 shadow-sm">
                    <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                    </svg>
                </div>
                <h2 class="font-bold text-xl mb-2 text-slate-900 dark:text-white group-hover:text-[#405EDB] transition-colors">{ui.en["index.tools.fb.title"]}</h2>
                <p class="text-[16px] text-slate-600 dark:text-slate-400 leading-relaxed">{ui.en["index.tools.fb.desc"]}</p>
            </a>


            <!-- YouTube Downloader - Coming Soon -->
            <div class="block p-8 rounded-2xl bg-[#F4F7FB] dark:bg-slate-800 opacity-60 cursor-not-allowed border border-transparent">
                <div class="w-14 h-14 rounded-xl bg-red-600 flex items-center justify-center mb-6 shadow-sm">
                    <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                    </svg>
                </div>
                <h2 class="font-bold text-xl mb-2 text-slate-900 dark:text-white">{ui.en["index.tools.yt.title"]}</h2>
                <p class="text-[16px] text-slate-600 dark:text-slate-400 leading-relaxed mb-3">{ui.en["index.tools.yt.desc"]}</p>
                <span class="inline-block text-xs font-semibold px-3 py-1 rounded-full bg-slate-200 dark:bg-slate-700 text-slate-600 dark:text-slate-300">{ui.en["index.tools.yt.badge"]}</span>
            </div>

            <!-- Video to MP3 -->
            <a href="/video-to-mp3/" class="group block p-8 rounded-2xl bg-[#F4F7FB] dark:bg-slate-800 border border-transparent hover:bg-white dark:hover:bg-slate-700 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                <div class="w-14 h-14 rounded-xl bg-[#405EDB] flex items-center justify-center mb-6 shadow-sm">
                    <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"/>
                    </svg>
                </div>
                <h2 class="font-bold text-xl mb-2 text-slate-900 dark:text-white group-hover:text-[#405EDB] transition-colors">{ui.en["index.tools.mp3.title"]}</h2>
                <p class="text-[16px] text-slate-600 dark:text-slate-400 leading-relaxed">{ui.en["index.tools.mp3.desc"]}</p>
            </a>

            <!-- Thumbnail Grabber -->
            <a href="/thumbnail-grabber/" class="group block p-8 rounded-2xl bg-[#F4F7FB] dark:bg-slate-800 border border-transparent hover:bg-white dark:hover:bg-slate-700 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                <div class="w-14 h-14 rounded-xl bg-[#405EDB] flex items-center justify-center mb-6 shadow-sm">
                    <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                </div>
                <h2 class="font-bold text-xl mb-2 text-slate-900 dark:text-white group-hover:text-[#405EDB] transition-colors">{ui.en["index.tools.thumbnail.title"]}</h2>
                <p class="text-[16px] text-slate-600 dark:text-slate-400 leading-relaxed">{ui.en["index.tools.thumbnail.desc"]}</p>
            </a>

        </div>

        <!-- Why Use MediaTools Section -->
        <div class="mt-32 max-w-5xl mx-auto">
            <h2 class="text-3xl font-extrabold text-center mb-12 text-slate-900 dark:text-white">{ui.en["index.why.title"]}</h2>
            <div class="grid gap-8 md:grid-cols-3">
                <div class="text-center p-6 border-none bg-transparent">
                    <div class="w-16 h-16 rounded-2xl bg-[#405EDB]/10 dark:bg-[#405EDB]/20 flex items-center justify-center mx-auto mb-6 transform hover:scale-110 transition-transform">
                        <span class="text-3xl">🆓</span>
                    </div>
                    <h3 class="font-bold text-xl mb-3 text-slate-900 dark:text-white">{ui.en["index.why.1.title"]}</h3>
                    <p class="text-[16px] text-slate-600 dark:text-slate-400 leading-relaxed">{ui.en["index.why.1.desc"]}</p>
                </div>
                <div class="text-center p-6 border-none bg-transparent">
                    <div class="w-16 h-16 rounded-2xl bg-[#405EDB]/10 dark:bg-[#405EDB]/20 flex items-center justify-center mx-auto mb-6 transform hover:scale-110 transition-transform">
                        <span class="text-3xl">🔒</span>
                    </div>
                    <h3 class="font-bold text-xl mb-3 text-slate-900 dark:text-white">{ui.en["index.why.2.title"]}</h3>
                    <p class="text-[16px] text-slate-600 dark:text-slate-400 leading-relaxed">{ui.en["index.why.2.desc"]}</p>
                </div>
                <div class="text-center p-6 border-none bg-transparent">
                    <div class="w-16 h-16 rounded-2xl bg-[#405EDB]/10 dark:bg-[#405EDB]/20 flex items-center justify-center mx-auto mb-6 transform hover:scale-110 transition-transform">
                        <span class="text-3xl">⚡</span>
                    </div>
                    <h3 class="font-bold text-xl mb-3 text-slate-900 dark:text-white">{ui.en["index.why.3.title"]}</h3>
                    <p class="text-[16px] text-slate-600 dark:text-slate-400 leading-relaxed">{ui.en["index.why.3.desc"]}</p>
                </div>
            </div>
        </div>

        <!-- Popular Guides Section -->
        <div class="mt-32 max-w-5xl mx-auto">
            <h2 class="text-3xl font-extrabold text-center mb-12 text-slate-900 dark:text-white">Popular Guides</h2>
            <div class="grid gap-6 sm:grid-cols-2">
                <a href="/blog/successful-faceless-youtube-channels/" class="group p-8 rounded-2xl bg-[#F4F7FB] dark:bg-slate-800 border border-transparent hover:bg-white dark:hover:bg-slate-700 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                    <h3 class="font-bold text-xl mb-3 text-slate-900 dark:text-white group-hover:text-[#405EDB] transition-colors">How to Build Successful Faceless YouTube Channels</h3>
                    <p class="text-[16px] text-slate-600 dark:text-slate-400 leading-relaxed">Learn the strategies behind faceless channels that earn thousands per month.</p>
                </a>
                <a href="/blog/how-to-become-a-content-creator/" class="group p-8 rounded-2xl bg-[#F4F7FB] dark:bg-slate-800 border border-transparent hover:bg-white dark:hover:bg-slate-700 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                    <h3 class="font-bold text-xl mb-3 text-slate-900 dark:text-white group-hover:text-[#405EDB] transition-colors">How to Become a Content Creator in 2026</h3>
                    <p class="text-[16px] text-slate-600 dark:text-slate-400 leading-relaxed">The ultimate guide to starting your content creation journey.</p>
                </a>
                <a href="/blog/best-tiktok-downloaders-2026/" class="group p-8 rounded-2xl bg-[#F4F7FB] dark:bg-slate-800 border border-transparent hover:bg-white dark:hover:bg-slate-700 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                    <h3 class="font-bold text-xl mb-3 text-slate-900 dark:text-white group-hover:text-[#405EDB] transition-colors">Best TikTok Downloaders in 2026</h3>
                    <p class="text-[16px] text-slate-600 dark:text-slate-400 leading-relaxed">Compare the top tools for downloading TikTok videos without watermark.</p>
                </a>
                <a href="/blog/mp3-juice-free-music-downloaders-safe/" class="group p-8 rounded-2xl bg-[#F4F7FB] dark:bg-slate-800 border border-transparent hover:bg-white dark:hover:bg-slate-700 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                    <h3 class="font-bold text-xl mb-3 text-slate-900 dark:text-white group-hover:text-[#405EDB] transition-colors">Is MP3Juice Safe? Free Music Downloaders Reviewed</h3>
                    <p class="text-[16px] text-slate-600 dark:text-slate-400 leading-relaxed">Safety review of popular free music download sites and better alternatives.</p>
                </a>
            </div>
        </div>
    </main>


    <Footer />
</Layout>

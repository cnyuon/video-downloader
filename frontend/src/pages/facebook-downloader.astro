---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer.astro';
import VideoDownloader from '../components/VideoDownloader';
import { ui } from '../i18n/ui';
import { getDiversePosts } from '../lib/blog-utils';

const lang = 'en';

const jsonLd = {
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "WebApplication",
            "name": "Facebook Video Downloader",
            "url": "https://getmediatools.com/facebook-downloader/",
            "description": ui.en['fb.meta.desc'],
            "applicationCategory": "MultimediaApplication",
            "operatingSystem": "Any",
            "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
        },
        {
            "@type": "HowTo",
            "name": ui.en['fb.howto.title'],
            "description": ui.en['fb.howto.desc'],
            "step": [
                { "@type": "HowToStep", "position": 1, "name": ui.en['fb.howto.step1.title'], "text": ui.en['fb.howto.step1.desc'] },
                { "@type": "HowToStep", "position": 2, "name": ui.en['fb.howto.step2.title'], "text": ui.en['fb.howto.step2.desc'] },
                { "@type": "HowToStep", "position": 3, "name": ui.en['fb.howto.step3.title'], "text": ui.en['fb.howto.step3.desc'] }
            ]
        },
        {
            "@type": "FAQPage",
            "mainEntity": [
                { "@type": "Question", "name": ui.en['fb.faq.q1'], "acceptedAnswer": { "@type": "Answer", "text": ui.en['fb.faq.a1'] } },
                { "@type": "Question", "name": ui.en['fb.faq.q2'], "acceptedAnswer": { "@type": "Answer", "text": ui.en['fb.faq.a2'] } },
                { "@type": "Question", "name": ui.en['fb.faq.q3'], "acceptedAnswer": { "@type": "Answer", "text": ui.en['fb.faq.a3'] } },
                { "@type": "Question", "name": ui.en['fb.faq.q4'], "acceptedAnswer": { "@type": "Answer", "text": ui.en['fb.faq.a4'] } },
                { "@type": "Question", "name": ui.en['fb.faq.q5'], "acceptedAnswer": { "@type": "Answer", "text": ui.en['fb.faq.a5'] } }
            ]
        }
    ]
};
const allPostsList = await getCollection('blog');
const enPosts = allPostsList.filter((p: any) => p.slug.startsWith('en/'));
const localPosts = allPostsList.filter((p: any) => p.slug.startsWith('en/'));
const displayPosts = localPosts.length > 0 ? localPosts : enPosts;
const diversePosts = getDiversePosts(displayPosts, 'facebook-downloader', 4);
---

<Layout 
    title={ui.en['fb.meta.title']}
    description={ui.en['fb.meta.desc']}
    jsonLd={jsonLd}
>
    <!-- Target Keywords: facebook video downloader, download facebook video, save fb video, facebook reels downloader, fb video saver -->
    <Navbar client:idle currentPage="facebook" lang={lang as keyof typeof ui} />
    
    <main class="container mx-auto px-4 pt-10 pb-4 max-w-2xl">
        <div class="text-center mb-10">
            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[#405EDB]/10 text-[#405EDB] border border-[#405EDB]/20 text-sm font-bold uppercase tracking-wider mb-5">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
                {ui.en['fb.hero.badge']}
            </div>
            <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-4 text-slate-900 dark:text-white leading-[1.1]">
                {ui.en['fb.hero.title']}
            </h1>
            <p class="text-lg text-slate-600 dark:text-slate-400 max-w-xl mx-auto leading-relaxed" set:html={ui.en['fb.hero.desc']} />
        </div>

        <VideoDownloader 
            client:load 
            placeholder={ui.en['fb.input.placeholder']} 
            allowedPlatform="facebook" 
            buttonGetVideo={ui.en['btn.get_video']}
            buttonDownloading={ui.en['btn.downloading']}
            buttonDownload={ui.en['btn.download_video']}
        />
        
        <!-- Features Section -->
        <div class="mt-16 grid gap-6 md:grid-cols-3">
            <div class="text-center p-8 rounded-2xl bg-[#F8FAFC] dark:bg-slate-800/50 shadow-sm border border-transparent">
                <div class="w-12 h-12 rounded-xl bg-[#405EDB]/10 flex items-center justify-center mx-auto mb-4">
                    <div class="text-2xl">🎬</div>
                </div>
                <h3 class="font-bold text-lg mb-2 text-slate-900 dark:text-white">{ui.en['fb.features.hd.title']}</h3>
                <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{ui.en['fb.features.hd.desc']}</p>
            </div>
            <div class="text-center p-8 rounded-2xl bg-[#F8FAFC] dark:bg-slate-800/50 shadow-sm border border-transparent">
                <div class="w-12 h-12 rounded-xl bg-[#405EDB]/10 flex items-center justify-center mx-auto mb-4">
                    <div class="text-2xl">📱</div>
                </div>
                <h3 class="font-bold text-lg mb-2 text-slate-900 dark:text-white">{ui.en['fb.features.reels.title']}</h3>
                <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{ui.en['fb.features.reels.desc']}</p>
            </div>
            <div class="text-center p-8 rounded-2xl bg-[#F8FAFC] dark:bg-slate-800/50 shadow-sm border border-transparent">
                <div class="w-12 h-12 rounded-xl bg-[#405EDB]/10 flex items-center justify-center mx-auto mb-4">
                    <div class="text-2xl">🔒</div>
                </div>
                <h3 class="font-bold text-lg mb-2 text-slate-900 dark:text-white">{ui.en['fb.features.nologin.title']}</h3>
                <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{ui.en['fb.features.nologin.desc']}</p>
            </div>
        </div>
        
        <!-- How To Section -->
        <div class="mt-20 py-10 border-t border-slate-100 dark:border-slate-800">
            <h2 class="text-3xl font-extrabold text-center mb-4 text-slate-900 dark:text-white">{ui.en['fb.howto.title']}</h2>
            <p class="text-center text-slate-600 dark:text-slate-400 mb-10 max-w-lg mx-auto leading-relaxed">{ui.en['fb.howto.desc']}</p>
            <div class="space-y-4 max-w-xl mx-auto">
                <div class="flex gap-5 items-start p-6 rounded-2xl bg-[#F8FAFC] dark:bg-slate-800/30">
                    <div class="flex-shrink-0 w-10 h-10 rounded-full bg-[#405EDB] text-white flex items-center justify-center font-bold shadow-md shadow-blue-500/20">1</div>
                    <div>
                        <h3 class="font-bold text-lg mb-1 text-slate-900 dark:text-white">{ui.en['fb.howto.step1.title']}</h3>
                        <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">{ui.en['fb.howto.step1.desc']}</p>
                    </div>
                </div>
                <div class="flex gap-5 items-start p-6 rounded-2xl bg-[#F8FAFC] dark:bg-slate-800/30">
                    <div class="flex-shrink-0 w-10 h-10 rounded-full bg-[#405EDB] text-white flex items-center justify-center font-bold shadow-md shadow-blue-500/20">2</div>
                    <div>
                        <h3 class="font-bold text-lg mb-1 text-slate-900 dark:text-white">{ui.en['fb.howto.step2.title']}</h3>
                        <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">{ui.en['fb.howto.step2.desc']}</p>
                    </div>
                </div>
                <div class="flex gap-5 items-start p-6 rounded-2xl bg-[#F8FAFC] dark:bg-slate-800/30">
                    <div class="flex-shrink-0 w-10 h-10 rounded-full bg-[#405EDB] text-white flex items-center justify-center font-bold shadow-md shadow-blue-500/20">3</div>
                    <div>
                        <h3 class="font-bold text-lg mb-1 text-slate-900 dark:text-white">{ui.en['fb.howto.step3.title']}</h3>
                        <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">{ui.en['fb.howto.step3.desc']}</p>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- FAQ Section for SEO -->
        <div class="mt-20 py-10 border-t border-slate-100 dark:border-slate-800">
            <h2 class="text-3xl font-extrabold text-center mb-8 text-slate-900 dark:text-white">{ui.en['fb.faq.title']}</h2>
            <div class="space-y-4 max-w-xl mx-auto">
                <div class="p-6 rounded-2xl bg-[#F8FAFC] dark:bg-slate-800/50 shadow-sm border border-transparent">
                    <h3 class="font-bold text-lg mb-2 text-slate-900 dark:text-white">{ui.en['fb.faq.q1']}</h3>
                    <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{ui.en['fb.faq.a1']}</p>
                </div>
                <div class="p-6 rounded-2xl bg-[#F8FAFC] dark:bg-slate-800/50 shadow-sm border border-transparent">
                    <h3 class="font-bold text-lg mb-2 text-slate-900 dark:text-white">{ui.en['fb.faq.q2']}</h3>
                    <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{ui.en['fb.faq.a2']}</p>
                </div>
                <div class="p-6 rounded-2xl bg-[#F8FAFC] dark:bg-slate-800/50 shadow-sm border border-transparent">
                    <h3 class="font-bold text-lg mb-2 text-slate-900 dark:text-white">{ui.en['fb.faq.q3']}</h3>
                    <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{ui.en['fb.faq.a3']}</p>
                </div>
                <div class="p-6 rounded-2xl bg-[#F8FAFC] dark:bg-slate-800/50 shadow-sm border border-transparent">
                    <h3 class="font-bold text-lg mb-2 text-slate-900 dark:text-white">{ui.en['fb.faq.q4']}</h3>
                    <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{ui.en['fb.faq.a4']}</p>
                </div>
                <div class="p-6 rounded-2xl bg-[#F8FAFC] dark:bg-slate-800/50 shadow-sm border border-transparent">
                    <h3 class="font-bold text-lg mb-2 text-slate-900 dark:text-white">{ui.en['fb.faq.q5']}</h3>
                    <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{ui.en['fb.faq.a5']}</p>
                </div>
            </div>
        </div>

        <!-- Related Guides Section -->
        <div class="mt-20 py-10 border-t border-slate-100 dark:border-slate-800">
            <h2 class="text-3xl font-extrabold text-center mb-8 text-slate-900 dark:text-white">{ui.en['fb.guides.title']}</h2>
            <div class="grid gap-6 md:grid-cols-2 max-w-3xl mx-auto">
                <a href={lang === 'en' ? '/tiktok-downloader/' : `/${lang}/tiktok-downloader/`} class="group p-6 rounded-2xl bg-[#F4F7FB] dark:bg-slate-800 border border-transparent hover:bg-white dark:hover:bg-slate-700 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                    <h3 class="font-bold text-lg mb-2 text-slate-900 dark:text-white group-hover:text-[#405EDB] transition-colors">{ui.en['fb.guides.1.title']}</h3>
                    <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{ui.en['fb.guides.1.desc']}</p>
                </a>
                <a href={lang === 'en' ? '/twitter-downloader/' : `/${lang}/twitter-downloader/`} class="group p-6 rounded-2xl bg-[#F4F7FB] dark:bg-slate-800 border border-transparent hover:bg-white dark:hover:bg-slate-700 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                    <h3 class="font-bold text-lg mb-2 text-slate-900 dark:text-white group-hover:text-[#405EDB] transition-colors">{ui.en['fb.guides.2.title']}</h3>
                    <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{ui.en['fb.guides.2.desc']}</p>
                </a>
            </div>
        </div>
    
        <!-- Recent Posts Section -->
        <div class="mt-20 pt-12 border-t border-slate-100 dark:border-slate-800 max-w-3xl mx-auto">
            <h2 class="text-2xl font-extrabold mb-8 text-slate-900 dark:text-white">{ui.en['nav.blog'] || "Blog"}</h2>
            <div class="grid gap-6 sm:grid-cols-2">
                {diversePosts.map((p: any) => {
                    const trueSlug = p.slug.split('/').pop();
                    return (
                        <a href={`/blog/${trueSlug}/`} class="group block p-6 rounded-2xl bg-[#F4F7FB] dark:bg-slate-800 border border-transparent hover:bg-white dark:hover:bg-slate-700 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                            <h3 class="font-bold text-lg text-slate-900 dark:text-white group-hover:text-[#405EDB] transition-colors line-clamp-2 mb-3">{p.data.title}</h3>
                            <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed line-clamp-2">{p.data.description}</p>
                        </a>
                    );
                })}
            </div>
            <div class="mt-10 text-center">
                <a href={`/blog/`} class="inline-flex items-center px-6 py-3 rounded-full bg-[#405EDB]/10 text-[#405EDB] font-bold text-sm hover:bg-[#405EDB] hover:text-white transition-colors duration-300">
                    {ui.en['btn.back_to_blog'] || "View all posts"}
                    <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </a>
            </div>
        </div>

    </main>

    <Footer />
</Layout>

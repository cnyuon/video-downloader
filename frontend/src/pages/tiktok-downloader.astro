---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer.astro';
import VideoDownloader from '../components/VideoDownloader';
import { ui } from '../i18n/ui';
import { getDiversePosts } from '../lib/blog-utils';

const lang = 'en';

const jsonLd = {
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "WebApplication",
            "name": "TikTok Video Downloader",
            "url": "https://getmediatools.com/tiktok-downloader/",
            "description": ui.en['tt.hero.desc'],
            "applicationCategory": "MultimediaApplication",
            "operatingSystem": "Any",
            "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
            "browserRequirements": "Requires JavaScript",
        },
        {
            "@type": "HowTo",
            "name": ui.en['tt.howto.title'],
            "description": ui.en['tt.howto.desc'],
            "step": [
                { "@type": "HowToStep", "position": 1, "name": ui.en['tt.howto.step1.title'], "text": ui.en['tt.howto.step1.desc'] },
                { "@type": "HowToStep", "position": 2, "name": ui.en['tt.howto.step2.title'], "text": ui.en['tt.howto.step2.desc'] },
                { "@type": "HowToStep", "position": 3, "name": ui.en['tt.howto.step3.title'], "text": ui.en['tt.howto.step3.desc'] }
            ]
        },
        {
            "@type": "FAQPage",
            "mainEntity": [
                { "@type": "Question", "name": ui.en['tt.faq.q1'], "acceptedAnswer": { "@type": "Answer", "text": ui.en['tt.faq.a1'] } },
                { "@type": "Question", "name": ui.en['tt.faq.q2'], "acceptedAnswer": { "@type": "Answer", "text": ui.en['tt.faq.a2'] } },
                { "@type": "Question", "name": ui.en['tt.faq.q3'], "acceptedAnswer": { "@type": "Answer", "text": ui.en['tt.faq.a3'] } },
                { "@type": "Question", "name": ui.en['tt.faq.q4'], "acceptedAnswer": { "@type": "Answer", "text": ui.en['tt.faq.a4'] } },
                { "@type": "Question", "name": ui.en['tt.faq.q5'], "acceptedAnswer": { "@type": "Answer", "text": ui.en['tt.faq.a5'] } }
            ]
        }
    ]
};
const allPostsList = await getCollection('blog');
const enPosts = allPostsList.filter((p: any) => p.slug.startsWith('en/'));
const localPosts = allPostsList.filter((p: any) => p.slug.startsWith('en/'));
const displayPosts = localPosts.length > 0 ? localPosts : enPosts;
const diversePosts = getDiversePosts(displayPosts, 'tiktok-downloader', 4);
---

<Layout 
    title={ui.en['tt.hero.title']}
    description={ui.en["tt.meta.desc"]}
    jsonLd={jsonLd}
>
    <!-- Target Keywords: tiktok downloader, download tiktok video no watermark, tiktok video saver, save tiktok without watermark, tiktok to mp4 -->
    <Navbar client:idle currentPage="video" lang={lang as keyof typeof ui} />
    
    <main class="container mx-auto px-4 pt-10 pb-4 max-w-2xl">
        <div class="text-center mb-10">
            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[#405EDB]/10 text-[#405EDB] border border-[#405EDB]/20 text-sm font-bold uppercase tracking-wider mb-5">
                <!-- TikTok logo with offset effect -->
                <div class="relative w-4 h-4">
                    <svg class="w-4 h-4 absolute" style="left: -1px; top: -1px;" viewBox="0 0 24 24" fill="#00f2ea">
                        <path d="M19.321 5.562a5.124 5.124 0 0 1-.443-.258 6.228 6.228 0 0 1-1.137-.966c-.849-.849-1.18-1.69-1.333-2.338h.003c-.11-.467-.073-.77-.066-.77h-3.547v13.473c0 .181 0 .359-.008.534a3.874 3.874 0 0 1-.022.287l-.001.021v.011a2.9 2.9 0 0 1-.881 1.838 2.87 2.87 0 0 1-2.028.824 2.9 2.9 0 0 1-2.9-2.9 2.9 2.9 0 0 1 2.9-2.9c.304 0 .596.049.868.138v-3.6a6.391 6.391 0 0 0-.868-.059 6.45 6.45 0 0 0-4.568 1.868A6.387 6.387 0 0 0 3.4 15.9a6.4 6.4 0 0 0 .389 2.187 6.452 6.452 0 0 0 1.5 2.1 6.437 6.437 0 0 0 4.568 1.88 6.45 6.45 0 0 0 4.568-1.88 6.394 6.394 0 0 0 1.89-4.568V9.55a9.372 9.372 0 0 0 5.49 1.77V7.77s-2.485.097-4.484-2.208z"/>
                    </svg>
                    <svg class="w-4 h-4 absolute" style="left: 1px; top: 1px;" viewBox="0 0 24 24" fill="#ff0050">
                        <path d="M19.321 5.562a5.124 5.124 0 0 1-.443-.258 6.228 6.228 0 0 1-1.137-.966c-.849-.849-1.18-1.69-1.333-2.338h.003c-.11-.467-.073-.77-.066-.77h-3.547v13.473c0 .181 0 .359-.008.534a3.874 3.874 0 0 1-.022.287l-.001.021v.011a2.9 2.9 0 0 1-.881 1.838 2.87 2.87 0 0 1-2.028.824 2.9 2.9 0 0 1-2.9-2.9 2.9 2.9 0 0 1 2.9-2.9c.304 0 .596.049.868.138v-3.6a6.391 6.391 0 0 0-.868-.059 6.45 6.45 0 0 0-4.568 1.868A6.387 6.387 0 0 0 3.4 15.9a6.4 6.4 0 0 0 .389 2.187 6.452 6.452 0 0 0 1.5 2.1 6.437 6.437 0 0 0 4.568 1.88 6.45 6.45 0 0 0 4.568-1.88 6.394 6.394 0 0 0 1.89-4.568V9.55a9.372 9.372 0 0 0 5.49 1.77V7.77s-2.485.097-4.484-2.208z"/>
                    </svg>
                    <svg class="w-4 h-4 relative z-10" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M19.321 5.562a5.124 5.124 0 0 1-.443-.258 6.228 6.228 0 0 1-1.137-.966c-.849-.849-1.18-1.69-1.333-2.338h.003c-.11-.467-.073-.77-.066-.77h-3.547v13.473c0 .181 0 .359-.008.534a3.874 3.874 0 0 1-.022.287l-.001.021v.011a2.9 2.9 0 0 1-.881 1.838 2.87 2.87 0 0 1-2.028.824 2.9 2.9 0 0 1-2.9-2.9 2.9 2.9 0 0 1 2.9-2.9c.304 0 .596.049.868.138v-3.6a6.391 6.391 0 0 0-.868-.059 6.45 6.45 0 0 0-4.568 1.868A6.387 6.387 0 0 0 3.4 15.9a6.4 6.4 0 0 0 .389 2.187 6.452 6.452 0 0 0 1.5 2.1 6.437 6.437 0 0 0 4.568 1.88 6.45 6.45 0 0 0 4.568-1.88 6.394 6.394 0 0 0 1.89-4.568V9.55a9.372 9.372 0 0 0 5.49 1.77V7.77s-2.485.097-4.484-2.208z"/>
                    </svg>
                </div>
                {ui.en['tt.hero.badge']}
            </div>
            <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-4 text-slate-900 dark:text-white leading-[1.1]">
                {ui.en['tt.hero.title']}
            </h1>
            <p class="text-lg text-slate-600 dark:text-slate-400 max-w-xl mx-auto leading-relaxed" set:html={ui.en['tt.hero.desc']} />
        </div>

        <VideoDownloader 
            client:load 
            placeholder={ui.en['tt.input.placeholder']} 
            allowedPlatform="tiktok" 
            buttonGetVideo={ui.en['btn.get_video']}
            buttonDownloading={ui.en['btn.downloading']}
            buttonDownload={ui.en['btn.download_video']}
        />
        
        <!-- Features Section -->
        <div class="mt-16 grid gap-6 md:grid-cols-3">
            <div class="text-center p-8 rounded-2xl bg-[#F8FAFC] dark:bg-slate-800/50 shadow-sm border border-transparent">
                <div class="w-12 h-12 rounded-xl bg-[#405EDB]/10 flex items-center justify-center mx-auto mb-4">
                    <div class="text-2xl">✨</div>
                </div>
                <h3 class="font-bold text-lg mb-2 text-slate-900 dark:text-white">{ui.en['tt.features.no_wm.title']}</h3>
                <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{ui.en['tt.features.no_wm.desc']}</p>
            </div>
            <div class="text-center p-8 rounded-2xl bg-[#F8FAFC] dark:bg-slate-800/50 shadow-sm border border-transparent">
                <div class="w-12 h-12 rounded-xl bg-[#405EDB]/10 flex items-center justify-center mx-auto mb-4">
                    <div class="text-2xl">📹</div>
                </div>
                <h3 class="font-bold text-lg mb-2 text-slate-900 dark:text-white">{ui.en['tt.features.hd.title']}</h3>
                <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{ui.en['tt.features.hd.desc']}</p>
            </div>
            <div class="text-center p-8 rounded-2xl bg-[#F8FAFC] dark:bg-slate-800/50 shadow-sm border border-transparent">
                <div class="w-12 h-12 rounded-xl bg-[#405EDB]/10 flex items-center justify-center mx-auto mb-4">
                    <div class="text-2xl">📱</div>
                </div>
                <h3 class="font-bold text-lg mb-2 text-slate-900 dark:text-white">{ui.en['tt.features.devices.title']}</h3>
                <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{ui.en['tt.features.devices.desc']}</p>
            </div>
        </div>
        
        <!-- How To Section -->
        <div class="mt-20 py-10 border-t border-slate-100 dark:border-slate-800">
            <h2 class="text-3xl font-extrabold text-center mb-4 text-slate-900 dark:text-white">{ui.en['tt.howto.title']}</h2>
            <p class="text-center text-slate-600 dark:text-slate-400 mb-10 max-w-lg mx-auto leading-relaxed">{ui.en['tt.howto.desc']}</p>
            <div class="space-y-4 max-w-xl mx-auto">
                <div class="flex gap-5 items-start p-6 rounded-2xl bg-[#F8FAFC] dark:bg-slate-800/30">
                    <div class="flex-shrink-0 w-10 h-10 rounded-full bg-[#405EDB] text-white flex items-center justify-center font-bold shadow-md shadow-blue-500/20">1</div>
                    <div>
                        <h3 class="font-bold text-lg mb-1 text-slate-900 dark:text-white">{ui.en['tt.howto.step1.title']}</h3>
                        <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">{ui.en['tt.howto.step1.desc']}</p>
                    </div>
                </div>
                <div class="flex gap-5 items-start p-6 rounded-2xl bg-[#F8FAFC] dark:bg-slate-800/30">
                    <div class="flex-shrink-0 w-10 h-10 rounded-full bg-[#405EDB] text-white flex items-center justify-center font-bold shadow-md shadow-blue-500/20">2</div>
                    <div>
                        <h3 class="font-bold text-lg mb-1 text-slate-900 dark:text-white">{ui.en['tt.howto.step2.title']}</h3>
                        <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">{ui.en['tt.howto.step2.desc']}</p>
                    </div>
                </div>
                <div class="flex gap-5 items-start p-6 rounded-2xl bg-[#F8FAFC] dark:bg-slate-800/30">
                    <div class="flex-shrink-0 w-10 h-10 rounded-full bg-[#405EDB] text-white flex items-center justify-center font-bold shadow-md shadow-blue-500/20">3</div>
                    <div>
                        <h3 class="font-bold text-lg mb-1 text-slate-900 dark:text-white">{ui.en['tt.howto.step3.title']}</h3>
                        <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">{ui.en['tt.howto.step3.desc']}</p>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- FAQ Section for SEO -->
        <div class="mt-20 py-10 border-t border-slate-100 dark:border-slate-800">
            <h2 class="text-3xl font-extrabold text-center mb-8 text-slate-900 dark:text-white">{ui.en['tt.faq.title']}</h2>
            <div class="space-y-4 max-w-xl mx-auto">
                <div class="p-6 rounded-2xl bg-[#F8FAFC] dark:bg-slate-800/50 shadow-sm border border-transparent">
                    <h3 class="font-bold text-lg mb-2 text-slate-900 dark:text-white">{ui.en['tt.faq.q1']}</h3>
                    <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{ui.en['tt.faq.a1']}</p>
                </div>
                <div class="p-6 rounded-2xl bg-[#F8FAFC] dark:bg-slate-800/50 shadow-sm border border-transparent">
                    <h3 class="font-bold text-lg mb-2 text-slate-900 dark:text-white">{ui.en['tt.faq.q2']}</h3>
                    <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{ui.en['tt.faq.a2']}</p>
                </div>
                <div class="p-6 rounded-2xl bg-[#F8FAFC] dark:bg-slate-800/50 shadow-sm border border-transparent">
                    <h3 class="font-bold text-lg mb-2 text-slate-900 dark:text-white">{ui.en['tt.faq.q3']}</h3>
                    <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{ui.en['tt.faq.a3']}</p>
                </div>
                <div class="p-6 rounded-2xl bg-[#F8FAFC] dark:bg-slate-800/50 shadow-sm border border-transparent">
                    <h3 class="font-bold text-lg mb-2 text-slate-900 dark:text-white">{ui.en['tt.faq.q4']}</h3>
                    <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{ui.en['tt.faq.a4']}</p>
                </div>
                <div class="p-6 rounded-2xl bg-[#F8FAFC] dark:bg-slate-800/50 shadow-sm border border-transparent">
                    <h3 class="font-bold text-lg mb-2 text-slate-900 dark:text-white">{ui.en['tt.faq.q5']}</h3>
                    <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{ui.en['tt.faq.a5']}</p>
                </div>
            </div>
        </div>

        <!-- Related Guides Section -->
        <div class="mt-20 py-10 border-t border-slate-100 dark:border-slate-800">
            <h2 class="text-3xl font-extrabold text-center mb-8 text-slate-900 dark:text-white">{ui.en['tt.guides.title']}</h2>
            <div class="grid gap-6 md:grid-cols-2 max-w-3xl mx-auto">
                <a href={lang === 'en' ? '/blog/how-to-download-tiktok-without-watermark/' : `/${lang}/blog/how-to-download-tiktok-without-watermark/`} class="group p-6 rounded-2xl bg-[#F4F7FB] dark:bg-slate-800 border border-transparent hover:bg-white dark:hover:bg-slate-700 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                    <h3 class="font-bold text-lg mb-2 text-slate-900 dark:text-white group-hover:text-[#405EDB] transition-colors">{ui.en['tt.guides.1.title']}</h3>
                    <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{ui.en['tt.guides.1.desc']}</p>
                </a>
                <a href={lang === 'en' ? '/blog/tiktok-banned-how-to-access-download/' : `/${lang}/blog/tiktok-banned-how-to-access-download/`} class="group p-6 rounded-2xl bg-[#F4F7FB] dark:bg-slate-800 border border-transparent hover:bg-white dark:hover:bg-slate-700 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                    <h3 class="font-bold text-lg mb-2 text-slate-900 dark:text-white group-hover:text-[#405EDB] transition-colors">{ui.en['tt.guides.2.title']}</h3>
                    <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{ui.en['tt.guides.2.desc']}</p>
                </a>
                <a href={lang === 'en' ? '/blog/best-free-video-editors-tiktok/' : `/${lang}/blog/best-free-video-editors-tiktok/`} class="group p-6 rounded-2xl bg-[#F4F7FB] dark:bg-slate-800 border border-transparent hover:bg-white dark:hover:bg-slate-700 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                    <h3 class="font-bold text-lg mb-2 text-slate-900 dark:text-white group-hover:text-[#405EDB] transition-colors">{ui.en['tt.guides.3.title']}</h3>
                    <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{ui.en['tt.guides.3.desc']}</p>
                </a>
                <a href={lang === 'en' ? '/tiktok-sound-downloader/' : `/${lang}/tiktok-sound-downloader/`} class="group p-6 rounded-2xl bg-[#F4F7FB] dark:bg-slate-800 border border-transparent hover:bg-white dark:hover:bg-slate-700 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                    <h3 class="font-bold text-lg mb-2 text-slate-900 dark:text-white group-hover:text-[#405EDB] transition-colors">{ui.en['tt.guides.4.title']}</h3>
                    <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{ui.en['tt.guides.4.desc']}</p>
                </a>
            </div>
        </div>
    
        <!-- Recent Posts Section -->
        <div class="mt-20 pt-12 border-t border-slate-100 dark:border-slate-800 max-w-3xl mx-auto">
            <h2 class="text-2xl font-extrabold mb-8 text-slate-900 dark:text-white">{ui.en['nav.blog'] || "Blog"}</h2>
            <div class="grid gap-6 sm:grid-cols-2">
                {diversePosts.map((p: any) => {
                    const trueSlug = p.slug.split('/').pop();
                    return (
                        <a href={`/blog/${trueSlug}/`} class="group block p-6 rounded-2xl bg-[#F4F7FB] dark:bg-slate-800 border border-transparent hover:bg-white dark:hover:bg-slate-700 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                            <h3 class="font-bold text-lg text-slate-900 dark:text-white group-hover:text-[#405EDB] transition-colors line-clamp-2 mb-3">{p.data.title}</h3>
                            <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed line-clamp-2">{p.data.description}</p>
                        </a>
                    );
                })}
            </div>
            <div class="mt-10 text-center">
                <a href={`/blog/`} class="inline-flex items-center px-6 py-3 rounded-full bg-[#405EDB]/10 text-[#405EDB] font-bold text-sm hover:bg-[#405EDB] hover:text-white transition-colors duration-300">
                    {ui.en['btn.back_to_blog'] || "View all posts"}
                    <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </a>
            </div>
        </div>

    </main>

    <Footer />
</Layout>

---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer.astro';

// Use English as the default fallback for the global 404
const lang = 'en';
---

<Layout 
    title="Page Not Found | GetMediaTools"
    description="The page you're looking for doesn't exist. Browse our creator toolkit guides, social media tips, and expert resources."
    robots="noindex, follow"
>
    <Navbar client:idle={{timeout: 3000}} currentPage="" lang={lang as any} />
    
    <main class="container mx-auto px-4 pt-20 pb-16 max-w-2xl text-center">
        <div class="text-6xl mb-6">🔍</div>
        <h1 class="text-4xl font-bold tracking-tight mb-4">Page Not Found</h1>
        <p class="text-lg text-muted-foreground mb-8">
            The page you're looking for doesn't exist or has been moved.
        </p>
        
        <div class="grid gap-4 sm:grid-cols-2 max-w-md mx-auto mb-12">
            <a href="/" class="px-6 py-3 rounded-xl bg-primary text-primary-foreground font-semibold hover:opacity-90 transition-opacity">
                Home
            </a>
            <a href="/blog/" class="px-6 py-3 rounded-xl border font-semibold hover:bg-accent transition-colors">
                Browse Articles
            </a>
        </div>

        <div class="text-left">
            <h2 class="text-xl font-bold mb-4">Popular Guides</h2>
            <div class="grid gap-3 sm:grid-cols-2">
                <a href="/blog/anonymous-tiktok-story-viewer/" class="p-3 rounded-lg border hover:border-primary/50 transition-colors text-sm">
                    <span class="font-semibold">Anonymous TikTok Viewer</span>
                    <p class="text-muted-foreground">Watch stories secretly</p>
                </a>
                <a href="/blog/download-instagram-reels-without-watermark/" class="p-3 rounded-lg border hover:border-primary/50 transition-colors text-sm">
                    <span class="font-semibold">Download Instagram Reels</span>
                    <p class="text-muted-foreground">Save Reels without watermark</p>
                </a>
                <a href="/blog/how-to-become-a-content-creator/" class="p-3 rounded-lg border hover:border-primary/50 transition-colors text-sm">
                    <span class="font-semibold">Become a Content Creator</span>
                    <p class="text-muted-foreground">Complete beginner guide</p>
                </a>
                <a href="/blog/best-tiktok-downloaders-2026/" class="p-3 rounded-lg border hover:border-primary/50 transition-colors text-sm">
                    <span class="font-semibold">Best TikTok Downloaders</span>
                    <p class="text-muted-foreground">Top tools compared</p>
                </a>
            </div>
        </div>
    </main>

    <Footer />
</Layout>

---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar';
import Footer from '../../../components/Footer.astro';
import { useTranslations } from '../../../i18n/utils';
import { ui } from '../../../i18n/ui';
import { Image } from 'astro:assets';
import { getDiversePosts } from '../../../lib/blog-utils';
import { getPhase1Text } from '../../../i18n/phase1-extra';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  const enPosts = allPosts.filter(post => post.slug.startsWith('en/'));
  
  // Only generate pages for posts that have actual translations
  return enPosts
    .filter((enPost) => {
      const trueSlug = enPost.slug.replace('en/', '');
      return allPosts.some(p => p.slug === `hi/${trueSlug}`);
    })
    .map((enPost) => {
      const trueSlug = enPost.slug.replace('en/', '');
      const nativePost = allPosts.find(p => p.slug === `hi/${trueSlug}`)!;
    
      return {
        params: { slug: trueSlug },
        props: {
            post: nativePost,
            originalSlug: trueSlug
        },
      };
    });
}

const { post, originalSlug } = Astro.props;



const { Content, headings } = await post.render();

// Category mapping helper
const CATEGORY_LABELS: Record<string, string> = {
    'vpn': 'Privacy & VPN',
    'software': 'Video Editing',
    'hosting': 'Creator Tech',
    'storage': 'Storage',
    'creator-tools': 'Growth Tools',
    'none': 'Guide'
};

const category = post.data.monetization?.primary_category 
    ? CATEGORY_LABELS[post.data.monetization.primary_category] 
    : 'Guide';

const lang = 'hi';
const t = useTranslations(lang);
const tx = (key: Parameters<typeof getPhase1Text>[1]) => getPhase1Text(String(lang), key);
const getHref = (path: string) => {
    let href = `/${lang}${path === '/' ? '' : path}`;
    return href.endsWith('/') ? href : href + '/';
};

const jsonLd = {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": post.data.title,
    "description": post.data.description,
    "datePublished": post.data.pubDate.toISOString(),
    "dateModified": (post.data.updatedDate || post.data.pubDate).toISOString(),
    "image": post.data.heroImage ? `https://getmediatools.com${(post.data.heroImage as any).src}` : undefined,
    "author": { "@type": "Organization", "name": "GetMediaTools" },
    "publisher": { "@type": "Organization", "name": "GetMediaTools", "url": "https://getmediatools.com" },
    "mainEntityOfPage": `https://getmediatools.com/${lang}/blog/${originalSlug}/`
};
const allPostsList = await getCollection('blog');
const enPosts = allPostsList.filter((p: any) => p.slug.startsWith('en/'));
const localPosts = allPostsList.filter((p: any) => p.slug.startsWith('hi/'));
const displayPosts = localPosts.length > 0 ? localPosts : enPosts;
const diversePosts = getDiversePosts(displayPosts, originalSlug, 4);
---

<Layout 
	title={post.data.title}
	description={post.data.description}
	ogImage={post.data.heroImage ? (post.data.heroImage as any).src : undefined}
	jsonLd={jsonLd}
	keywords={post.data.keywords}
	pubDate={post.data.pubDate}
	updatedDate={post.data.updatedDate}
>
	<Navbar client:idle={{timeout: 3000}} currentPage="blog" lang={lang as any} />
	
	<main class="container mx-auto px-4 pt-6 md:pt-10 pb-12 max-w-5xl">
        <!-- Breadcrumb -->
        <nav class="flex items-center text-sm font-bold text-slate-600 mb-8 overflow-hidden whitespace-nowrap" aria-label="Breadcrumb">
            <a href={getHref('/')} class="hover:text-slate-900 dark:hover:text-white transition-colors shrink-0">{tx('blog.detail.home')}</a>
            <svg class="w-4 h-4 mx-2 text-slate-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" /></svg>
            <a href={getHref('/blog/')} class="hover:text-slate-900 dark:hover:text-white transition-colors shrink-0">{t('nav.blog')}</a>
            <svg class="w-4 h-4 mx-2 text-slate-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" /></svg>
            <span class="text-slate-900 dark:text-white truncate">{post.data.title}</span>
        </nav>

		<article class="mx-auto">
			
            <div class="flex flex-col lg:flex-row gap-16 lg:gap-20 max-w-5xl mx-auto relative items-start">
                
                <!-- Main Content -->
                <div class="w-full lg:w-[68%] shrink-0">
                    <!-- Header inside main content column -->
                    <header class="mb-8 text-left">
                        <h1 class="text-3xl md:text-4xl lg:text-5xl font-serif font-bold tracking-normal mb-6 text-slate-900 dark:text-white leading-[1.15]">
                            {post.data.title}
                        </h1>
                        <p class="text-base md:text-lg text-slate-700 dark:text-slate-300 leading-relaxed max-w-3xl font-serif">
                            {post.data.description}
                        </p>
                    </header>
                    
                    {post.data.heroImage && (
                        <div class="rounded-2xl overflow-hidden border border-slate-200 dark:border-slate-800 mb-10 md:mb-12 aspect-[16/9] w-full bg-slate-100 dark:bg-slate-800">
                            <Image 
                                src={post.data.heroImage as any} 
                                alt={post.data.heroAlt || post.data.title} 
                                class="w-full h-full object-contain"
                                loading="eager"
                                width={1600}
                                height={900}
                                format="webp"
                            />
                        </div>
                    )}

                    {/* Removed Manual Table of Contents Box - Handled by Markdown + Sidebar now */}

                    <div class="prose max-w-none text-slate-800 dark:text-slate-300
                        prose-headings:font-extrabold prose-headings:tracking-tight prose-headings:text-slate-900 dark:prose-headings:text-white
                        prose-a:font-bold prose-a:text-[#405EDB] prose-a:no-underline hover:prose-a:underline hover:prose-a:decoration-[#405EDB]/30 hover:prose-a:decoration-4 hover:prose-a:underline-offset-4 prose-a:transition-all
                        prose-p:leading-loose
                        prose-img:rounded-2xl prose-img:shadow-sm prose-img:border prose-img:border-slate-200 dark:prose-img:border-slate-800 prose-img:my-10
                        prose-strong:text-slate-900 dark:prose-strong:text-white prose-strong:font-extrabold
                        prose-ul:leading-loose prose-ol:leading-loose prose-li:my-2
                        prose-table:block prose-table:w-full prose-table:overflow-x-auto sm:prose-table:table sm:prose-table:overflow-x-visible prose-table:rounded-xl prose-table:border prose-table:border-slate-200 dark:prose-table:border-slate-800 prose-table:shadow-sm prose-table:whitespace-nowrap sm:prose-table:whitespace-normal
                        prose-th:bg-slate-50 dark:prose-th:bg-slate-800/50 prose-th:p-4 prose-th:text-left prose-th:font-extrabold prose-th:text-slate-900 dark:prose-th:text-white
                        prose-td:p-4 prose-td:border-t prose-td:border-slate-100 dark:prose-td:border-slate-800 prose-tr:nth-child(even):bg-slate-50/50 dark:prose-tr:nth-child(even):bg-slate-800/30">
        				<Content />
                    </div>
                </div>

                <!-- Sidebar Desktop -->
                <aside class="w-full lg:w-[32%] sticky top-24 hidden lg:block">

                    <!-- Post Content (TOC) -->
                    {headings.length > 0 && (
                        <div class="mb-10">
                            <h3 class="font-bold text-[13px] text-slate-600 dark:text-slate-300 uppercase tracking-widest mb-4 flex items-center gap-2">
                                <div class="w-1 h-4 bg-[#405EDB] rounded-full"></div>
                                {tx('blog.detail.toc')}
                            </h3>
                            <ul class="space-y-3 m-0 p-0 list-none border-l-2 border-slate-100 dark:border-slate-800 pl-4 py-1">
                                {headings.filter(h => h.depth <= 3).map((heading) => (
                                    <li class={`leading-snug ${heading.depth === 3 ? 'ml-4' : 'ml-0'}`}>
                                        <a href={`#${heading.slug}`} class="text-[14px] text-slate-700 dark:text-slate-300 hover:text-[#405EDB] dark:hover:text-[#405EDB] hover:font-bold transition-all line-clamp-2">
                                            {heading.text}
                                        </a>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    )}

                                                            <!-- Related Topics & Offers -->
                    <div>
                        <h3 class="font-bold text-[13px] text-slate-600 dark:text-slate-300 uppercase tracking-widest mb-4">
                            {tx('blog.detail.related_posts')}
                        </h3>
                        <div class="space-y-4">
                            {diversePosts.slice(0, 3).map((p: any) => {
                                const trueSlug = p.slug.split('/').pop();
                                return (
                                    <a href={getHref(`/blog/${trueSlug}/`)} class="group block p-4 rounded-xl bg-transparent hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors relative overflow-hidden -mx-4">
                                        <!-- Decorative ticket cutout effect -->
                                        <div class="absolute left-[-8px] top-1/2 -translate-y-1/2 w-4 h-4 bg-white dark:bg-slate-950 rounded-full border-r border-slate-200 dark:border-slate-800 z-10 group-hover:border-[#405EDB] transition-colors"></div>
                                        <div class="absolute right-[-8px] top-1/2 -translate-y-1/2 w-4 h-4 bg-white dark:bg-slate-950 rounded-full border-l border-slate-200 dark:border-slate-800 z-10 group-hover:border-[#405EDB] transition-colors"></div>
                                        
                                        <h4 class="font-bold text-slate-900 dark:text-white group-hover:text-[#405EDB] transition-colors line-clamp-2 text-[15px] mb-2 leading-snug px-2">{p.data.title}</h4>
                                        <p class="text-[13px] text-slate-600 dark:text-slate-300 px-2 line-clamp-2 mb-4">{tx('blog.detail.related_teaser')}</p>
                                        
                                        <div class="border-t border-slate-100 dark:border-slate-800 pt-3 flex items-center mt-3 mx-2">
                                            <span class="text-[12px] font-bold text-slate-600 uppercase tracking-wider group-hover:text-[#405EDB] transition-colors">{tx('blog.detail.read_article')} &rarr;</span>
                                        </div>
                                    </a>
                                );
                            })}
                        </div>
                    </div>
                </aside>
            </div>
		</article>

        <!-- Sidebar Mobile / Fallback below content -->
        <div class="mt-16 lg:hidden w-full bg-transparent border-t border-slate-100 dark:border-slate-800 pt-8 sm:pt-12">
            <h3 class="font-extrabold text-xl text-slate-900 dark:text-white mb-6">
                {tx('blog.detail.related_posts')}
            </h3>
            <div class="grid gap-4 sm:grid-cols-2">
                {diversePosts.slice(0, 4).map((p: any) => {
                    const trueSlug = p.slug.split('/').pop();
                    return (
                        <a href={getHref(`/blog/${trueSlug}/`)} class="group flex items-center gap-4 p-4 rounded-xl bg-[#F8FAFC] dark:bg-slate-800/50 hover:bg-slate-50 dark:hover:bg-slate-800 border-transparent transition-all">
                            <div class="w-16 h-16 shrink-0 rounded-lg overflow-hidden bg-slate-200 dark:bg-slate-700 relative">
                                {p.data.heroImage && (
                                    <Image 
                                        src={p.data.heroImage as any} 
                                        alt={p.data.title} 
                                        class="w-full h-full object-cover group-hover:scale-105 transition-transform"
                                        width={100} height={100} format="webp"
                                    />
                                )}
                            </div>
                            <div>
                                <h4 class="font-bold text-slate-900 dark:text-white group-hover:text-[#405EDB] transition-colors line-clamp-2 text-sm leading-snug">{p.data.title}</h4>
                                <span class="text-xs text-slate-600 dark:text-slate-300 font-medium mt-1 inline-block">{tx('blog.detail.read_article')} &rarr;</span>
                            </div>
                        </a>
                    );
                })}
            </div>
        </div>
	</main>

    <Footer />
</Layout>

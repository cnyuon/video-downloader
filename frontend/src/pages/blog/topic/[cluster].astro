---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar';
import Footer from '../../../components/Footer.astro';
import { Image } from 'astro:assets';
import { BLOG_CLUSTERS, getClusterMeta, getPostCluster } from '../../../lib/blog-taxonomy';

export function getStaticPaths() {
    return BLOG_CLUSTERS.map((cluster: (typeof BLOG_CLUSTERS)[number]) => ({ params: { cluster: cluster.id } }));
}

const clusterId = String(Astro.params.cluster || '');
const clusterMeta = getClusterMeta(clusterId as any);

const allPosts = await getCollection('blog');
const posts = allPosts
    .filter((post) => post.slug.startsWith('en/'))
    .filter((post) => getPostCluster(post) === clusterMeta.id)
    .sort((a, b) => (b.data.updatedDate || b.data.pubDate).valueOf() - (a.data.updatedDate || a.data.pubDate).valueOf());
---

<Layout
    title={`${clusterMeta.title} | GetMediaTools Blog`}
    description={clusterMeta.description}
>
    <Navbar client:idle={{timeout: 3000}} currentPage="blog" lang={'en'} />

    <main class="container mx-auto px-4 pt-10 pb-16 max-w-6xl">
        <div class="mb-10">
            <a href="/blog/" class="text-sm font-bold text-[#405EDB] hover:underline">&larr; Back to Blog</a>
            <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mt-4 mb-4 text-slate-900 dark:text-white">{clusterMeta.title}</h1>
            <p class="text-lg text-slate-600 dark:text-slate-400 max-w-3xl">{clusterMeta.description}</p>
        </div>

        <div class="grid gap-6 sm:gap-8 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
            {posts.map((post) => {
                const trueSlug = post.slug.replace(/^en\//, '');
                return (
                    <article class="group bg-[#F8FAFC] dark:bg-slate-800/50 rounded-2xl sm:rounded-3xl border border-transparent shadow-sm hover:bg-white dark:hover:bg-slate-700 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 h-full flex flex-col overflow-hidden">
                        <a href={`/blog/${trueSlug}/`} class="block w-full aspect-[16/9] overflow-hidden bg-slate-100 dark:bg-slate-800 relative shrink-0">
                            {post.data.heroImage ? (
                                <Image
                                    src={post.data.heroImage as any}
                                    alt={post.data.title}
                                    class="w-full h-full object-contain group-hover:scale-[1.01] transition-transform duration-500"
                                    loading="lazy"
                                    width={1600}
                                    height={900}
                                    format="webp"
                                />
                            ) : (
                                <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-slate-100 to-slate-200 dark:from-slate-800 dark:to-slate-900">
                                    <span class="text-5xl opacity-50">📄</span>
                                </div>
                            )}
                        </a>
                        <div class="p-5 sm:p-8 flex-1 flex flex-col">
                            <h2 class="text-xl sm:text-2xl font-extrabold mb-2 sm:mb-4 line-clamp-2 text-slate-900 dark:text-white group-hover:text-[#405EDB] transition-colors leading-tight">
                                <a href={`/blog/${trueSlug}/`}>{post.data.title}</a>
                            </h2>
                            <p class="text-slate-600 dark:text-slate-400 mb-4 sm:mb-8 line-clamp-3 flex-1 text-sm sm:text-base leading-relaxed">{post.data.description}</p>
                            <div class="pt-2 sm:pt-4 mt-auto">
                                <a href={`/blog/${trueSlug}/`} class="inline-flex items-center px-4 sm:px-5 py-2 sm:py-2.5 rounded-xl bg-slate-100 dark:bg-slate-800 text-slate-900 dark:text-white font-bold text-xs sm:text-sm hover:bg-[#405EDB] hover:text-white transition-all duration-300">
                                    Read Article
                                </a>
                            </div>
                        </div>
                    </article>
                );
            })}
        </div>
    </main>

    <Footer />
</Layout>

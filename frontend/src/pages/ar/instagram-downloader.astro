---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar';
import Footer from '../../components/Footer.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { ui } from '../../i18n/ui';
import { getDiversePosts } from '../../lib/blog-utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const getHref = (path: string) => {
    let href = lang === 'en' ? path : `/${lang}${path === '/' ? '' : path}`;
    return href.endsWith('/') ? href : href + '/';
};

const jsonLd = {
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "WebApplication",
            "name": "Instagram Downloader",
            "url": `https://getmediatools.com/${lang}/instagram-downloader/`,
            "description": "Download Instagram Reels, Stories, and videos in HD quality. Free, no watermark, works on iPhone, Android & desktop.",
            "applicationCategory": "MultimediaApplication",
            "operatingSystem": "Any",
            "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
            "browserRequirements": "Requires JavaScript",
        },
        {
            "@type": "FAQPage",
            "mainEntity": [
                { "@type": "Question", "name": "Can I download Instagram Reels without watermark?", "acceptedAnswer": { "@type": "Answer", "text": "Yes! Our Instagram downloader saves Reels in HD quality without any watermarks." } },
                { "@type": "Question", "name": "Does the Instagram downloader work on iPhone?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, it works directly in Safari or Chrome on iOS. No app installation required." } },
                { "@type": "Question", "name": "Is it free to download Instagram videos?", "acceptedAnswer": { "@type": "Answer", "text": "Absolutely free. No hidden fees, no premium plans, no signup required." } }
            ]
        }
    ]
};

const allPostsList = await getCollection('blog');
const enPosts = allPostsList.filter((p: any) => p.slug.startsWith('en/'));
const localPosts = allPostsList.filter((p: any) => p.slug.startsWith(`${lang}/`));
const displayPosts = localPosts.length > 0 ? localPosts : enPosts;
const diversePosts = getDiversePosts(displayPosts, 'instagram-downloader', 4);
---

<Layout
    title="Instagram Downloader — Save Reels & Videos in HD (Free)"
    description="Download Instagram Reels, Stories, and videos in HD quality. Free, no watermark, works on iPhone, Android & desktop."
    jsonLd={jsonLd}
>
    <Navbar client:idle={{timeout: 3000}} currentPage="home" lang={lang as keyof typeof ui} />

    <main class="container mx-auto px-4 pt-10 pb-4 max-w-2xl">
        <div class="text-center mb-8">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-sm font-medium mb-4" style="background: linear-gradient(135deg, #833AB4, #FD1D1D, #F77737); color: white;">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
                Instagram
            </div>
            <h1 class="text-4xl font-bold tracking-tight mb-3">Instagram Downloader</h1>
            <p class="text-lg text-muted-foreground max-w-xl mx-auto">
                Download Instagram Reels, Stories, and videos in <strong>HD quality</strong> — free, no watermark, no app needed.
            </p>
        </div>

        <div class="rounded-xl border bg-card p-6 mb-6">
            <div class="flex gap-2">
                <input type="text" placeholder="Paste Instagram link here..." class="flex-1 px-4 py-3 rounded-lg border bg-background text-foreground placeholder:text-muted-foreground focus:outline-none opacity-60" disabled />
                <button class="px-6 py-3 rounded-lg font-semibold text-white opacity-60 cursor-not-allowed" style="background: linear-gradient(135deg, #833AB4, #FD1D1D, #F77737);" disabled>Get Video</button>
            </div>
            <div class="mt-4 p-3 rounded-lg bg-amber-50 dark:bg-amber-950/30 border border-amber-200 dark:border-amber-800">
                <p class="text-sm text-amber-800 dark:text-amber-200 flex items-center gap-2">
                    <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
                    <span><strong>Coming Soon</strong> — Our Instagram downloader is being upgraded. Check out the related guides below.</span>
                </p>
            </div>
        </div>

        <div class="mt-12 py-8 border-t">
            <h2 class="text-2xl font-bold text-center mb-6">Related Guides</h2>
            <div class="grid gap-4 md:grid-cols-2">
                <a href={getHref('/blog/download-instagram-reels-without-watermark/')} class="group p-4 rounded-xl border bg-card hover:border-primary/50 hover:shadow-md transition-all">
                    <h3 class="font-semibold mb-1 group-hover:text-primary transition-colors">How to Download Instagram Reels Without Watermark</h3>
                    <p class="text-sm text-muted-foreground">Step-by-step guide with alternative methods.</p>
                </a>
                <a href={getHref('/tiktok-downloader/')} class="group p-4 rounded-xl border bg-card hover:border-primary/50 hover:shadow-md transition-all">
                    <h3 class="font-semibold mb-1 group-hover:text-primary transition-colors">{t('nav.tiktok')}</h3>
                    <p class="text-sm text-muted-foreground">{t('index.tools.tt.desc')}</p>
                </a>
                <a href={getHref('/facebook-downloader/')} class="group p-4 rounded-xl border bg-card hover:border-primary/50 hover:shadow-md transition-all">
                    <h3 class="font-semibold mb-1 group-hover:text-primary transition-colors">{t('nav.facebook')}</h3>
                    <p class="text-sm text-muted-foreground">{t('index.tools.fb.desc')}</p>
                </a>
                <a href={getHref('/video-to-mp3/')} class="group p-4 rounded-xl border bg-card hover:border-primary/50 hover:shadow-md transition-all">
                    <h3 class="font-semibold mb-1 group-hover:text-primary transition-colors">{t('nav.audio')}</h3>
                    <p class="text-sm text-muted-foreground">{t('index.tools.mp3.desc')}</p>
                </a>
            </div>
        </div>

        <div class="mt-20 pt-12 border-t max-w-2xl mx-auto">
            <h2 class="text-2xl font-bold mb-6">{t('nav.blog')}</h2>
            <div class="grid gap-4 sm:grid-cols-2">
                {diversePosts.map((p: any) => {
                    const trueSlug = p.slug.split('/').pop();
                    return (
                        <a href={getHref(`/blog/${trueSlug}/`)} class="group block p-4 rounded-xl border bg-card hover:border-primary/50 hover:shadow-md transition-all">
                            <h3 class="font-semibold group-hover:text-primary transition-colors line-clamp-2 mb-2">{p.data.title}</h3>
                            <p class="text-sm text-muted-foreground line-clamp-2">{p.data.description}</p>
                        </a>
                    );
                })}
            </div>
        </div>
    </main>

    <Footer />
</Layout>

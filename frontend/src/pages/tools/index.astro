---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar';
import Footer from '../../components/Footer.astro';
import { ui } from '../../i18n/ui';
import { getPhase1Text } from '../../i18n/phase1-extra';
import { TOOL_CATEGORIES } from '../../lib/tool-categories';

const lang = 'en';
const tx = (key: Parameters<typeof getPhase1Text>[1]) => getPhase1Text(lang, key);
const CATEGORY_THEME: Record<string, { icon: string; shell: string; pill: string; cardHover: string }> = {
    video: {
        icon: '🎬',
        shell: 'from-indigo-50 to-blue-50 dark:from-indigo-950/30 dark:to-blue-950/20',
        pill: 'bg-indigo-100 text-indigo-700 dark:bg-indigo-900/50 dark:text-indigo-200',
        cardHover: 'hover:border-indigo-300 dark:hover:border-indigo-700/70',
    },
    audio: {
        icon: '🎵',
        shell: 'from-emerald-50 to-teal-50 dark:from-emerald-950/30 dark:to-teal-950/20',
        pill: 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/50 dark:text-emerald-200',
        cardHover: 'hover:border-emerald-300 dark:hover:border-emerald-700/70',
    },
    image: {
        icon: '🖼️',
        shell: 'from-amber-50 to-orange-50 dark:from-amber-950/30 dark:to-orange-950/20',
        pill: 'bg-amber-100 text-amber-700 dark:bg-amber-900/50 dark:text-amber-200',
        cardHover: 'hover:border-amber-300 dark:hover:border-amber-700/70',
    },
};
---

<Layout title={`${tx('tools.hub.title')} | GetMediaTools`} description={tx('tools.hub.desc')}>
    <Navbar client:idle={{timeout: 3000}} currentPage="tools" lang={lang as keyof typeof ui} />

    <main class="container mx-auto px-4 pt-8 pb-20 max-w-6xl">
        <div class="relative overflow-hidden rounded-[2rem] md:rounded-[2.5rem] mb-14 border border-slate-800 bg-gradient-to-br from-[#0f172a] via-[#121f45] to-[#1f3b8f] px-6 py-10 md:px-12 md:py-14">
            <div class="absolute -top-20 -right-20 w-72 h-72 rounded-full bg-cyan-400/20 blur-3xl"></div>
            <div class="absolute -bottom-20 -left-20 w-72 h-72 rounded-full bg-indigo-500/20 blur-3xl"></div>
            <div class="relative text-center">
                <span class="inline-flex items-center rounded-full border border-white/20 bg-white/10 px-4 py-1.5 text-[11px] font-extrabold uppercase tracking-[0.18em] text-cyan-100">
                    GetMediaTools
                </span>
                <h1 class="mt-5 text-4xl md:text-5xl font-extrabold tracking-tight text-white">{tx('tools.hub.title')}</h1>
                <p class="mt-4 text-base md:text-lg text-slate-200 max-w-3xl mx-auto leading-relaxed">{tx('tools.hub.desc')}</p>
            </div>
        </div>

        <div class="space-y-10">
            {TOOL_CATEGORIES.map((category) => (
                <section class={`rounded-3xl border border-slate-200 dark:border-slate-800 bg-gradient-to-br ${CATEGORY_THEME[category.id].shell} p-6 sm:p-8`}>
                    <div class="mb-6 flex items-center justify-between gap-4 flex-wrap">
                        <h2 class="text-2xl sm:text-3xl font-extrabold text-slate-900 dark:text-white flex items-center gap-3">
                            <span class="text-2xl">{CATEGORY_THEME[category.id].icon}</span>
                            {category.id === 'video' ? tx('tools.category.video') : category.id === 'audio' ? tx('tools.category.audio') : tx('tools.category.image')}
                        </h2>
                        <span class={`inline-flex items-center rounded-full px-3 py-1 text-xs font-bold uppercase tracking-wider ${CATEGORY_THEME[category.id].pill}`}>
                            {category.tools.length}
                        </span>
                    </div>
                    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
                        {category.tools.map((tool) => (
                            <a href={tool.href} class={`group rounded-2xl border border-slate-200/80 dark:border-slate-700/80 p-6 bg-white/90 dark:bg-slate-900/70 ${CATEGORY_THEME[category.id].cardHover} hover:shadow-xl hover:-translate-y-1 transition-all duration-300`}>
                                <h3 class="font-bold text-lg text-slate-900 dark:text-white group-hover:text-[#405EDB] transition-colors">
                                    {tool.id === 'instagram' ? tx('nav.instagram') : ui.en[tool.labelKey]}
                                </h3>
                                <p class="mt-3 text-sm text-slate-600 dark:text-slate-400 leading-relaxed" set:html={tool.id === 'instagram' ? tx('tools.instagram.desc') : tool.descriptionKey ? ui.en[tool.descriptionKey] : tool.fallbackDescription} />
                            </a>
                        ))}
                    </div>
                </section>
            ))}
        </div>
    </main>

    <Footer />
</Layout>

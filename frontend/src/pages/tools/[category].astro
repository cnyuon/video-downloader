---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar';
import Footer from '../../components/Footer.astro';
import { ui } from '../../i18n/ui';
import { TOOL_CATEGORY_IDS, getToolCategory } from '../../lib/tool-categories';

export function getStaticPaths() {
    return TOOL_CATEGORY_IDS.map((category) => ({ params: { category } }));
}

const lang = 'en';
const category = String(Astro.params.category || '');
const categoryData = getToolCategory(category);
if (!categoryData) {
    throw new Error(`Unknown tool category: ${category}`);
}
---

<Layout title={`${ui.en[categoryData.titleKey]} | GetMediaTools`} description={ui.en['tools.hub.desc']}>
    <Navbar client:idle={{timeout: 3000}} currentPage="tools-menu" lang={lang as keyof typeof ui} />

    <main class="container mx-auto px-4 pt-10 pb-20 max-w-5xl">
        <div class="mb-10">
            <a href="/tools/" class="text-sm font-bold text-[#405EDB] hover:underline">&larr; Back to All Tools</a>
            <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mt-4 mb-4 text-slate-900 dark:text-white">{ui.en[categoryData.titleKey]}</h1>
            <p class="text-lg text-slate-600 dark:text-slate-400 max-w-3xl">{ui.en['tools.hub.desc']}</p>
        </div>

        <div class="grid gap-6 sm:grid-cols-2">
            {categoryData.tools.map((tool) => (
                <a href={tool.href} class="group rounded-2xl border border-slate-200 dark:border-slate-800 p-7 bg-white dark:bg-slate-900 hover:border-[#405EDB] hover:shadow-lg transition-all">
                    <h2 class="font-bold text-xl text-slate-900 dark:text-white group-hover:text-[#405EDB] transition-colors">{ui.en[tool.labelKey]}</h2>
                    <p class="mt-3 text-sm text-slate-600 dark:text-slate-400 leading-relaxed" set:html={tool.descriptionKey ? ui.en[tool.descriptionKey] : tool.fallbackDescription} />
                </a>
            ))}
        </div>
    </main>

    <Footer />
</Layout>

---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer.astro';
import { ui } from '../i18n/ui';
import { getDiversePosts } from '../lib/blog-utils';

const lang = 'en';

const jsonLd = {
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "WebApplication",
            "name": "Instagram Downloader",
            "url": "https://getmediatools.com/instagram-downloader/",
            "description": "Download Instagram Reels, Stories, and videos in HD quality. Free, no watermark, works on iPhone, Android & desktop.",
            "applicationCategory": "MultimediaApplication",
            "operatingSystem": "Any",
            "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
            "browserRequirements": "Requires JavaScript",
        },
        {
            "@type": "FAQPage",
            "mainEntity": [
                { "@type": "Question", "name": "Can I download Instagram Reels without watermark?", "acceptedAnswer": { "@type": "Answer", "text": "Yes! Our Instagram downloader saves Reels in HD quality without any watermarks. Just paste the Reel link and download." } },
                { "@type": "Question", "name": "Does the Instagram downloader work on iPhone?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, it works directly in Safari or Chrome on iOS. No app installation required." } },
                { "@type": "Question", "name": "Is it free to download Instagram videos?", "acceptedAnswer": { "@type": "Answer", "text": "Absolutely free. No hidden fees, no premium plans, no signup required." } },
                { "@type": "Question", "name": "Can I download private Instagram videos?", "acceptedAnswer": { "@type": "Answer", "text": "No, our tool respects privacy and can only download content from public accounts." } },
                { "@type": "Question", "name": "What formats are supported?", "acceptedAnswer": { "@type": "Answer", "text": "Videos are downloaded in MP4 format in the highest available quality (up to 1080p HD)." } }
            ]
        }
    ]
};

const allPostsList = await getCollection('blog');
const enPosts = allPostsList.filter((p: any) => p.slug.startsWith('en/'));
const diversePosts = getDiversePosts(enPosts, 'instagram-downloader', 4);
---

<Layout
    title="Instagram Downloader — Save Reels & Videos in HD (Free)"
    description="Download Instagram Reels, Stories, and videos in HD quality. Free, no watermark, works on iPhone, Android & desktop. No app needed."
    jsonLd={jsonLd}
    keywords={["instagram downloader", "download instagram reels", "save instagram video", "instagram to mp4", "download reels without watermark"]}
>
    <Navbar client:idle currentPage="home" lang={lang as keyof typeof ui} />

    <main class="container mx-auto px-4 pt-10 pb-4 max-w-2xl">
        <div class="text-center mb-8">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-sm font-medium mb-4" style="background: linear-gradient(135deg, #833AB4, #FD1D1D, #F77737); color: white;">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
                Instagram
            </div>
            <h1 class="text-4xl font-bold tracking-tight mb-3">
                Instagram Downloader
            </h1>
            <p class="text-lg text-muted-foreground max-w-xl mx-auto">
                Download Instagram Reels, Stories, and videos in <strong>HD quality</strong> — free, no watermark, no app needed.
            </p>
        </div>

        <!-- Download Input (Currently Unavailable) -->
        <div class="rounded-xl border bg-card p-6 mb-6">
            <div class="flex gap-2">
                <input
                    type="text"
                    placeholder="Paste Instagram link here..."
                    class="flex-1 px-4 py-3 rounded-lg border bg-background text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 opacity-60"
                    disabled
                />
                <button
                    class="px-6 py-3 rounded-lg font-semibold text-white opacity-60 cursor-not-allowed"
                    style="background: linear-gradient(135deg, #833AB4, #FD1D1D, #F77737);"
                    disabled
                >
                    Get Video
                </button>
            </div>
            <div class="mt-4 p-3 rounded-lg bg-amber-50 dark:bg-amber-950/30 border border-amber-200 dark:border-amber-800">
                <p class="text-sm text-amber-800 dark:text-amber-200 flex items-center gap-2">
                    <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/>
                    </svg>
                    <span><strong>Coming Soon</strong> — Our Instagram downloader is being upgraded. In the meantime, check out the guide below for alternative methods.</span>
                </p>
            </div>
        </div>

        <!-- Features Section -->
        <div class="mt-12 grid gap-4 md:grid-cols-3">
            <div class="text-center p-4 rounded-lg bg-muted/30">
                <div class="text-2xl mb-2">🎬</div>
                <h3 class="font-semibold mb-1">Reels & Stories</h3>
                <p class="text-sm text-muted-foreground">Download Reels, Stories, and regular video posts from any public account.</p>
            </div>
            <div class="text-center p-4 rounded-lg bg-muted/30">
                <div class="text-2xl mb-2">📹</div>
                <h3 class="font-semibold mb-1">HD Quality</h3>
                <p class="text-sm text-muted-foreground">Save videos in the highest available quality, up to 1080p Full HD.</p>
            </div>
            <div class="text-center p-4 rounded-lg bg-muted/30">
                <div class="text-2xl mb-2">📱</div>
                <h3 class="font-semibold mb-1">All Devices</h3>
                <p class="text-sm text-muted-foreground">Works on iPhone, Android, Windows, and Mac — right in your browser.</p>
            </div>
        </div>

        <!-- How To Section -->
        <div class="mt-12 py-8 border-t">
            <h2 class="text-2xl font-bold text-center mb-2">How to Download Instagram Videos</h2>
            <p class="text-center text-muted-foreground mb-6 max-w-lg mx-auto">Three simple steps — no app or signup needed.</p>
            <div class="space-y-4">
                <div class="flex gap-4 items-start">
                    <div class="flex-shrink-0 w-8 h-8 rounded-full bg-primary text-primary-foreground flex items-center justify-center font-bold">1</div>
                    <div>
                        <h3 class="font-semibold">Copy the Link</h3>
                        <p class="text-muted-foreground text-sm">Open Instagram, find the Reel or video, tap ⋯ → Copy Link.</p>
                    </div>
                </div>
                <div class="flex gap-4 items-start">
                    <div class="flex-shrink-0 w-8 h-8 rounded-full bg-primary text-primary-foreground flex items-center justify-center font-bold">2</div>
                    <div>
                        <h3 class="font-semibold">Paste & Download</h3>
                        <p class="text-muted-foreground text-sm">Paste the link above and click "Get Video" to fetch the download.</p>
                    </div>
                </div>
                <div class="flex gap-4 items-start">
                    <div class="flex-shrink-0 w-8 h-8 rounded-full bg-primary text-primary-foreground flex items-center justify-center font-bold">3</div>
                    <div>
                        <h3 class="font-semibold">Save to Device</h3>
                        <p class="text-muted-foreground text-sm">Tap "Download Video" to save the HD video directly to your device.</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- FAQ Section -->
        <div class="mt-12 py-8 border-t">
            <h2 class="text-2xl font-bold text-center mb-6">Frequently Asked Questions</h2>
            <div class="space-y-4">
                <div class="p-4 rounded-lg bg-muted/30">
                    <h3 class="font-semibold mb-2">Can I download Instagram Reels without watermark?</h3>
                    <p class="text-sm text-muted-foreground">Yes! Our Instagram downloader saves Reels in HD quality without any watermarks. Just paste the Reel link and download.</p>
                </div>
                <div class="p-4 rounded-lg bg-muted/30">
                    <h3 class="font-semibold mb-2">Does this work on iPhone?</h3>
                    <p class="text-sm text-muted-foreground">Yes, it works directly in Safari or Chrome on iOS. No app installation required.</p>
                </div>
                <div class="p-4 rounded-lg bg-muted/30">
                    <h3 class="font-semibold mb-2">Is it free to download Instagram videos?</h3>
                    <p class="text-sm text-muted-foreground">Absolutely free. No hidden fees, no premium plans, no signup required.</p>
                </div>
                <div class="p-4 rounded-lg bg-muted/30">
                    <h3 class="font-semibold mb-2">Can I download private Instagram videos?</h3>
                    <p class="text-sm text-muted-foreground">No, our tool respects privacy and can only download content from public accounts.</p>
                </div>
                <div class="p-4 rounded-lg bg-muted/30">
                    <h3 class="font-semibold mb-2">What formats are supported?</h3>
                    <p class="text-sm text-muted-foreground">Videos are downloaded in MP4 format in the highest available quality (up to 1080p HD).</p>
                </div>
            </div>
        </div>

        <!-- Related Guides Section -->
        <div class="mt-12 py-8 border-t">
            <h2 class="text-2xl font-bold text-center mb-6">Related Guides</h2>
            <div class="grid gap-4 md:grid-cols-2">
                <a href="/blog/download-instagram-reels-without-watermark/" class="group p-4 rounded-xl border bg-card hover:border-primary/50 hover:shadow-md transition-all">
                    <h3 class="font-semibold mb-1 group-hover:text-primary transition-colors">How to Download Instagram Reels Without Watermark</h3>
                    <p class="text-sm text-muted-foreground">Step-by-step guide with alternative methods that work right now.</p>
                </a>
                <a href="/tiktok-downloader/" class="group p-4 rounded-xl border bg-card hover:border-primary/50 hover:shadow-md transition-all">
                    <h3 class="font-semibold mb-1 group-hover:text-primary transition-colors">TikTok Video Downloader</h3>
                    <p class="text-sm text-muted-foreground">Download TikTok videos without watermark in HD quality.</p>
                </a>
                <a href="/facebook-downloader/" class="group p-4 rounded-xl border bg-card hover:border-primary/50 hover:shadow-md transition-all">
                    <h3 class="font-semibold mb-1 group-hover:text-primary transition-colors">Facebook Video Downloader</h3>
                    <p class="text-sm text-muted-foreground">Save Facebook Reels and videos to your device.</p>
                </a>
                <a href="/video-to-mp3/" class="group p-4 rounded-xl border bg-card hover:border-primary/50 hover:shadow-md transition-all">
                    <h3 class="font-semibold mb-1 group-hover:text-primary transition-colors">Video to MP3 Converter</h3>
                    <p class="text-sm text-muted-foreground">Extract audio from any social media video as MP3.</p>
                </a>
            </div>
        </div>

        <!-- Recent Posts Section -->
        <div class="mt-20 pt-12 border-t max-w-2xl mx-auto">
            <h2 class="text-2xl font-bold mb-6">{ui.en['nav.blog'] || "Blog"}</h2>
            <div class="grid gap-4 sm:grid-cols-2">
                {diversePosts.map((p: any) => {
                    const trueSlug = p.slug.split('/').pop();
                    return (
                        <a href={`/blog/${trueSlug}/`} class="group block p-4 rounded-xl border bg-card hover:border-primary/50 hover:shadow-md transition-all">
                            <h3 class="font-semibold group-hover:text-primary transition-colors line-clamp-2 mb-2">{p.data.title}</h3>
                            <p class="text-sm text-muted-foreground line-clamp-2">{p.data.description}</p>
                        </a>
                    );
                })}
            </div>
            <div class="mt-6 text-center">
                <a href="/blog/" class="inline-flex items-center text-sm font-medium text-primary hover:underline">
                    {ui.en['btn.back_to_blog'] || "View all posts"}
                    <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </a>
            </div>
        </div>

    </main>

    <Footer />
</Layout>

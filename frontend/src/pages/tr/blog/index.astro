---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar';
import Footer from '../../../components/Footer.astro';
import { useTranslations } from '../../../i18n/utils';
import { ui } from '../../../i18n/ui';
import { Image } from 'astro:assets';

const lang = 'tr';
const t = useTranslations(lang);
const allBlogPosts = await getCollection('blog');

// Get baseline posts and sort
const baselinePosts = allBlogPosts.filter(post => post.slug.startsWith('en/'));
const sortedBaseline = baselinePosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Map to localized versions if they exist
const localizedPosts = sortedBaseline.map(enPost => {
    const trueSlug = enPost.slug.replace('en/', '');
    const nativePost = allBlogPosts.find(p => p.slug === `${lang}/${trueSlug}`);
    return {
        ...(nativePost || enPost),
        slug: trueSlug
    };
});

// Category helper
const CATEGORY_LABELS: Record<string, string> = {
    'vpn': 'Privacy & VPN',
    'software': 'Video Editing',
    'hosting': 'Creator Tech',
    'storage': 'Storage',
    'creator-tools': 'Growth Tools',
    'none': 'Guide'
};

function getCategoryLabel(slug: string | undefined): string {
    return slug && CATEGORY_LABELS[slug] ? CATEGORY_LABELS[slug] : 'Guide';
}

const getHref = (path: string) => {
    let href = `/${lang}${path === '/' ? '' : path}`;
    return href.endsWith('/') ? href : href + '/';
};

const jsonLd = {
    "@context": "https://schema.org",
    "@type": "Blog",
    "name": "MediaTools Blog",
    "url": `https://getmediatools.com/${lang}/blog/`
};
---

<Layout 
    title={`${t('blog.title')} — Video Download Guides, Tips & Creator Tools`}
    description={t('blog.desc')}
    jsonLd={jsonLd}
>
    <!-- Target Keywords: video downloading tips, tiktok download guide, remove watermarks, free online tools blog -->
    <Navbar client:idle currentPage="blog" lang={lang as any} />
    
    <main class="container mx-auto px-4 pt-10 pb-16 max-w-6xl">
        <div class="text-center mb-16">
            <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-6 text-slate-900 dark:text-white leading-[1.1]">
                GetMediaTools Blog
            </h1>
            <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto leading-relaxed">
                {t('blog.desc')}
            </p>
        </div>
        
        <!-- TODO: Implement category filtering with client-side JS when blog grows -->

        <div class="grid gap-6 sm:gap-8 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
            {localizedPosts.map((post) => (
                <article class="group bg-[#F8FAFC] dark:bg-slate-800/50 rounded-2xl sm:rounded-3xl border border-transparent shadow-sm hover:bg-white dark:hover:bg-slate-700 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 h-full flex flex-col sm:flex-col overflow-hidden">
                    <a href={getHref(`/blog/${post.slug}/`)} class="block w-full sm:w-full aspect-video sm:aspect-[4/3] overflow-hidden bg-slate-100 dark:bg-slate-800 relative shrink-0">
                        {post.data.heroImage ? (
                            <Image 
                                src={post.data.heroImage as any} 
                                alt={post.data.title} 
                                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                                loading="lazy"
                                width={800}
                                height={800}
                                format="webp"
                            />
                        ) : (
                            <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-slate-100 to-slate-200 dark:from-slate-800 dark:to-slate-900 group-hover:scale-105 transition-transform duration-700">
                                <span class="text-5xl opacity-50">📄</span>
                            </div>
                        )}
                        <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                    </a>
                    <div class="p-5 sm:p-8 flex-1 flex flex-col">
                        <div class="flex items-center justify-between mb-3 sm:mb-5">
                            <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] sm:text-xs font-bold uppercase tracking-wider bg-[#405EDB]/10 text-[#405EDB]">
                                {getCategoryLabel(post.data.monetization?.primary_category)}
                            </span>
                        </div>
                        
                        <h2 class="text-xl sm:text-2xl font-extrabold mb-2 sm:mb-4 line-clamp-2 text-slate-900 dark:text-white group-hover:text-[#405EDB] transition-colors leading-tight">
                            <a href={getHref(`/blog/${post.slug}/`)}>
                                {post.data.title}
                            </a>
                        </h2>
                        
                        <p class="text-slate-600 dark:text-slate-400 mb-4 sm:mb-8 line-clamp-2 sm:line-clamp-3 flex-1 text-sm sm:text-base leading-relaxed">
                            {post.data.description}
                        </p>
                        
                        <div class="pt-2 sm:pt-4 mt-auto">
                            <a href={getHref(`/blog/${post.slug}/`)} class="inline-flex items-center px-4 sm:px-5 py-2 sm:py-2.5 rounded-xl bg-slate-100 dark:bg-slate-800 text-slate-900 dark:text-white font-bold text-xs sm:text-sm hover:bg-[#405EDB] hover:text-white transition-all duration-300 group/link">
                                {t('btn.read_article')}
                                <svg class="w-4 h-4 ml-1.5 transform group-hover/link:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                                </svg>
                            </a>
                        </div>
                    </div>
                </article>
            ))}
        </div>
    </main>

    <Footer />
</Layout>

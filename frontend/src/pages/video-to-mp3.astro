---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer.astro';
import AudioExtractor from '../components/AudioExtractor';
import { ui } from '../i18n/ui';
import { getDiversePosts } from '../lib/blog-utils';

const lang = 'en';

const jsonLd = {
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "WebApplication",
            "name": "Video to MP3 Converter",
            "url": "https://getmediatools.com/video-to-mp3/",
            "description": ui.en['mp3.meta.desc'],
            "applicationCategory": "MultimediaApplication",
            "operatingSystem": "Any",
            "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
        },
        {
            "@type": "HowTo",
            "name": ui.en['mp3.howto.title'],
            "description": ui.en['mp3.howto.desc'],
            "step": [
                { "@type": "HowToStep", "position": 1, "name": ui.en['mp3.howto.step1.title'], "text": ui.en['mp3.howto.step1.desc'] },
                { "@type": "HowToStep", "position": 2, "name": ui.en['mp3.howto.step2.title'], "text": ui.en['mp3.howto.step2.desc'] },
                { "@type": "HowToStep", "position": 3, "name": ui.en['mp3.howto.step3.title'], "text": ui.en['mp3.howto.step3.desc'] }
            ]
        },
        {
            "@type": "FAQPage",
            "mainEntity": [
                { "@type": "Question", "name": ui.en['mp3.faq.q1'], "acceptedAnswer": { "@type": "Answer", "text": ui.en['mp3.faq.a1'] } },
                { "@type": "Question", "name": ui.en['mp3.faq.q2'], "acceptedAnswer": { "@type": "Answer", "text": ui.en['mp3.faq.a2'] } },
                { "@type": "Question", "name": ui.en['mp3.faq.q3'], "acceptedAnswer": { "@type": "Answer", "text": ui.en['mp3.faq.a3'] } },
                { "@type": "Question", "name": ui.en['mp3.faq.q4'], "acceptedAnswer": { "@type": "Answer", "text": ui.en['mp3.faq.a4'] } },
                { "@type": "Question", "name": ui.en['mp3.faq.q5'], "acceptedAnswer": { "@type": "Answer", "text": ui.en['mp3.faq.a5'] } }
            ]
        }
    ]
};
const allPostsList = await getCollection('blog');
const enPosts = allPostsList.filter((p: any) => p.slug.startsWith('en/'));
const localPosts = allPostsList.filter((p: any) => p.slug.startsWith('en/'));
const displayPosts = localPosts.length > 0 ? localPosts : enPosts;
const diversePosts = getDiversePosts(displayPosts, 'video-to-mp3', 4);
---

<Layout 
    title={ui.en['mp3.meta.title']}
    description={ui.en['mp3.meta.desc']}
    jsonLd={jsonLd}
>
    <Navbar client:idle={{timeout: 3000}} currentPage="audio" lang={lang as keyof typeof ui} />
    
    <main class="container mx-auto px-4 pt-10 pb-4 max-w-2xl">
        <div class="text-center mb-10">
            <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-4 text-slate-900 dark:text-white leading-[1.1]">
                {ui.en['mp3.hero.title']}
            </h1>
            <p class="text-lg text-slate-600 dark:text-slate-400 max-w-xl mx-auto leading-relaxed">
                {ui.en['mp3.hero.desc']}
            </p>
            
            <!-- Supported Platforms -->
            <div class="flex items-center justify-center gap-4 mt-6">
                <span class="text-sm font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">{ui.en['mp3.hero.works_with']}</span>
                <div class="flex items-center gap-3">
                    <!-- TikTok -->
                    <div class="w-8 h-8 rounded-lg bg-gradient-to-r from-[#ff0050] to-[#00f2ea] flex items-center justify-center shadow-sm" title="TikTok">
                        <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
                        </svg>
                    </div>
                    <!-- Twitter/X -->
                    <div class="w-8 h-8 rounded-lg bg-black flex items-center justify-center shadow-sm text-white" title="Twitter/X">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                        </svg>
                    </div>
                    <!-- Facebook -->
                    <div class="w-8 h-8 rounded-lg bg-[#1877F2] flex items-center justify-center shadow-sm text-white" title="Facebook">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                        </svg>
                    </div>
                </div>
            </div>
        </div>

        <AudioExtractor 
            client:load 
            placeholderUrl={ui.en['mp3.input.placeholder']}
            buttonGetInfo={ui.en['btn.get_info']}
            buttonExtracting={ui.en['btn.extracting']}
            buttonDownloaded={ui.en['btn.downloaded']}
            buttonExtractMp3={ui.en['btn.extract_mp3']}
            buttonExtractOriginal={ui.en['btn.extract_original']}
            textOriginalAudio={ui.en['text.original_audio']}
            textConvertedMp3={ui.en['text.converted_mp3']}
        />

        <!-- Features Section -->
        <div class="mt-16 grid gap-6 md:grid-cols-3">
            <div class="text-center p-8 rounded-2xl bg-[#F8FAFC] dark:bg-slate-800/50 shadow-sm border border-transparent">
                <div class="w-12 h-12 rounded-xl bg-[#405EDB]/10 flex items-center justify-center mx-auto mb-4">
                    <div class="text-2xl">🎵</div>
                </div>
                <h3 class="font-bold text-lg mb-2 text-slate-900 dark:text-white">{ui.en['mp3.features.hq.title']}</h3>
                <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{ui.en['mp3.features.hq.desc']}</p>
            </div>
            <div class="text-center p-8 rounded-2xl bg-[#F8FAFC] dark:bg-slate-800/50 shadow-sm border border-transparent">
                <div class="w-12 h-12 rounded-xl bg-[#405EDB]/10 flex items-center justify-center mx-auto mb-4">
                    <div class="text-2xl">⚡</div>
                </div>
                <h3 class="font-bold text-lg mb-2 text-slate-900 dark:text-white">{ui.en['mp3.features.instant.title']}</h3>
                <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{ui.en['mp3.features.instant.desc']}</p>
            </div>
            <div class="text-center p-8 rounded-2xl bg-[#F8FAFC] dark:bg-slate-800/50 shadow-sm border border-transparent">
                <div class="w-12 h-12 rounded-xl bg-[#405EDB]/10 flex items-center justify-center mx-auto mb-4">
                    <div class="text-2xl">🆓</div>
                </div>
                <h3 class="font-bold text-lg mb-2 text-slate-900 dark:text-white">{ui.en['mp3.features.free.title']}</h3>
                <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{ui.en['mp3.features.free.desc']}</p>
            </div>
        </div>

        <!-- How To Section -->
        <div class="mt-20 py-10 border-t border-slate-100 dark:border-slate-800">
            <h2 class="text-3xl font-extrabold text-center mb-4 text-slate-900 dark:text-white">{ui.en['mp3.howto.title']}</h2>
            <p class="text-center text-slate-600 dark:text-slate-400 mb-10 max-w-lg mx-auto leading-relaxed">{ui.en['mp3.howto.desc']}</p>
            <div class="space-y-4 max-w-xl mx-auto">
                <div class="flex gap-5 items-start p-6 rounded-2xl bg-[#F8FAFC] dark:bg-slate-800/30">
                    <div class="flex-shrink-0 w-10 h-10 rounded-full bg-[#405EDB] text-white flex items-center justify-center font-bold shadow-md shadow-blue-500/20">1</div>
                    <div>
                        <h3 class="font-bold text-lg mb-1 text-slate-900 dark:text-white">{ui.en['mp3.howto.step1.title']}</h3>
                        <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">{ui.en['mp3.howto.step1.desc']}</p>
                    </div>
                </div>
                <div class="flex gap-5 items-start p-6 rounded-2xl bg-[#F8FAFC] dark:bg-slate-800/30">
                    <div class="flex-shrink-0 w-10 h-10 rounded-full bg-[#405EDB] text-white flex items-center justify-center font-bold shadow-md shadow-blue-500/20">2</div>
                    <div>
                        <h3 class="font-bold text-lg mb-1 text-slate-900 dark:text-white">{ui.en['mp3.howto.step2.title']}</h3>
                        <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">{ui.en['mp3.howto.step2.desc']}</p>
                    </div>
                </div>
                <div class="flex gap-5 items-start p-6 rounded-2xl bg-[#F8FAFC] dark:bg-slate-800/30">
                    <div class="flex-shrink-0 w-10 h-10 rounded-full bg-[#405EDB] text-white flex items-center justify-center font-bold shadow-md shadow-blue-500/20">3</div>
                    <div>
                        <h3 class="font-bold text-lg mb-1 text-slate-900 dark:text-white">{ui.en['mp3.howto.step3.title']}</h3>
                        <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">{ui.en['mp3.howto.step3.desc']}</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- FAQ Section -->
        <div class="mt-20 py-10 border-t border-slate-100 dark:border-slate-800">
            <h2 class="text-3xl font-extrabold text-center mb-8 text-slate-900 dark:text-white">{ui.en['mp3.faq.title']}</h2>
            <div class="space-y-4 max-w-xl mx-auto">
                <div class="p-6 rounded-2xl bg-[#F8FAFC] dark:bg-slate-800/50 shadow-sm border border-transparent">
                    <h3 class="font-bold text-lg mb-2 text-slate-900 dark:text-white">{ui.en['mp3.faq.q1']}</h3>
                    <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{ui.en['mp3.faq.a1']}</p>
                </div>
                <div class="p-6 rounded-2xl bg-[#F8FAFC] dark:bg-slate-800/50 shadow-sm border border-transparent">
                    <h3 class="font-bold text-lg mb-2 text-slate-900 dark:text-white">{ui.en['mp3.faq.q2']}</h3>
                    <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{ui.en['mp3.faq.a2']}</p>
                </div>
                <div class="p-6 rounded-2xl bg-[#F8FAFC] dark:bg-slate-800/50 shadow-sm border border-transparent">
                    <h3 class="font-bold text-lg mb-2 text-slate-900 dark:text-white">{ui.en['mp3.faq.q3']}</h3>
                    <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{ui.en['mp3.faq.a3']}</p>
                </div>
                <div class="p-6 rounded-2xl bg-[#F8FAFC] dark:bg-slate-800/50 shadow-sm border border-transparent">
                    <h3 class="font-bold text-lg mb-2 text-slate-900 dark:text-white">{ui.en['mp3.faq.q4']}</h3>
                    <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{ui.en['mp3.faq.a4']}</p>
                </div>
                <div class="p-6 rounded-2xl bg-[#F8FAFC] dark:bg-slate-800/50 shadow-sm border border-transparent">
                    <h3 class="font-bold text-lg mb-2 text-slate-900 dark:text-white">{ui.en['mp3.faq.q5']}</h3>
                    <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{ui.en['mp3.faq.a5']}</p>
                </div>
            </div>
        </div>

        <!-- Related Guides Section -->
        <div class="mt-20 py-10 border-t border-slate-100 dark:border-slate-800">
            <h2 class="text-3xl font-extrabold text-center mb-8 text-slate-900 dark:text-white">{ui.en['mp3.guides.title']}</h2>
            <div class="grid gap-6 md:grid-cols-2 max-w-3xl mx-auto">
                <a href={lang === 'en' ? '/tiktok-sound-downloader/' : `/${lang}/tiktok-sound-downloader/`} class="group p-6 rounded-2xl bg-[#F4F7FB] dark:bg-slate-800 border border-transparent hover:bg-white dark:hover:bg-slate-700 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                    <h3 class="font-bold text-lg mb-2 text-slate-900 dark:text-white group-hover:text-[#405EDB] transition-colors">{ui.en['mp3.guides.1.title']}</h3>
                    <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{ui.en['mp3.guides.1.desc']}</p>
                </a>
                <a href={lang === 'en' ? '/tiktok-downloader/' : `/${lang}/tiktok-downloader/`} class="group p-6 rounded-2xl bg-[#F4F7FB] dark:bg-slate-800 border border-transparent hover:bg-white dark:hover:bg-slate-700 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                    <h3 class="font-bold text-lg mb-2 text-slate-900 dark:text-white group-hover:text-[#405EDB] transition-colors">{ui.en['mp3.guides.2.title']}</h3>
                    <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{ui.en['mp3.guides.2.desc']}</p>
                </a>
            </div>
        </div>
    
        <!-- Recent Posts Section -->
        <div class="mt-20 pt-12 border-t border-slate-100 dark:border-slate-800 max-w-3xl mx-auto">
            <h2 class="text-2xl font-extrabold mb-8 text-slate-900 dark:text-white">{ui.en['nav.blog'] || "Blog"}</h2>
            <div class="grid gap-6 sm:grid-cols-2">
                {diversePosts.map((p: any) => {
                    const trueSlug = p.slug.split('/').pop();
                    return (
                        <a href={`/blog/${trueSlug}/`} class="group block p-6 rounded-2xl bg-[#F4F7FB] dark:bg-slate-800 border border-transparent hover:bg-white dark:hover:bg-slate-700 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                            <h3 class="font-bold text-lg text-slate-900 dark:text-white group-hover:text-[#405EDB] transition-colors line-clamp-2 mb-3">{p.data.title}</h3>
                            <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed line-clamp-2">{p.data.description}</p>
                        </a>
                    );
                })}
            </div>
            <div class="mt-10 text-center">
                <a href={`/blog/`} class="inline-flex items-center px-6 py-3 rounded-full bg-[#405EDB]/10 text-[#405EDB] font-bold text-sm hover:bg-[#405EDB] hover:text-white transition-colors duration-300">
                    {ui.en['btn.back_to_blog'] || "View all posts"}
                    <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </a>
            </div>
        </div>

    </main>

    <Footer />
</Layout>

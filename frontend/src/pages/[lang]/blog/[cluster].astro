---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar';
import Footer from '../../../components/Footer.astro';
import { Image } from 'astro:assets';
import { ui } from '../../../i18n/ui';
import { useTranslations } from '../../../i18n/utils';
import { NON_DEFAULT_LOCALES } from '../../../i18n/locales';
import { getPhase1Text } from '../../../i18n/phase1-extra';
import { BLOG_CLUSTERS, getClusterMeta, getPostCluster } from '../../../lib/blog-taxonomy';

export function getStaticPaths() {
    return NON_DEFAULT_LOCALES.flatMap((lang) =>
        BLOG_CLUSTERS.map((cluster: (typeof BLOG_CLUSTERS)[number]) => ({ params: { lang, cluster: cluster.id } }))
    );
}

const localeParam = String(Astro.params.lang || 'en');
const locale = (Object.keys(ui).includes(localeParam) ? localeParam : 'en') as keyof typeof ui;
const localeCode = String(locale);
const t = useTranslations(locale);
const tx = (key: Parameters<typeof getPhase1Text>[1]) => getPhase1Text(localeCode, key);

const clusterId = String(Astro.params.cluster || '');
const clusterMeta = getClusterMeta(clusterId as any);
const clusterName = tx(`blog.cluster.${clusterMeta.id}` as any);
const clusterDescription = tx(`blog.cluster_desc.${clusterMeta.id}` as any);

const allPosts = await getCollection('blog');
const posts = allPosts
    .filter((post) => post.slug.startsWith(`${localeCode}/`) || (localeCode !== 'en' && post.slug.startsWith('en/')))
    .filter((post) => {
        const normalized = post.slug.replace(/^[a-z]{2}\//, '');
        const hasLocalizedVersion = allPosts.some((p) => p.slug === `${localeCode}/${normalized}`);
        if (post.slug.startsWith('en/') && localeCode !== 'en' && hasLocalizedVersion) return false;
        return true;
    })
    .filter((post) => getPostCluster(post) === clusterMeta.id)
    .sort((a, b) => (b.data.updatedDate || b.data.pubDate).valueOf() - (a.data.updatedDate || a.data.pubDate).valueOf());

const getHref = (path: string) => (localeCode === 'en' ? path : `/${localeCode}${path === '/' ? '/' : path}`);
---

<Layout
    title={`${clusterName} | GetMediaTools Blog`}
    description={clusterDescription}
>
    <Navbar client:idle={{timeout: 3000}} currentPage="blog" lang={locale} />

    <main class="container mx-auto px-4 pt-10 pb-16 max-w-6xl">
        <div class="mb-10">
            <a href={getHref('/blog/')} class="text-sm font-bold text-[#405EDB] hover:underline">&larr; {t('nav.blog')}</a>
            <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mt-4 mb-4 text-slate-900 dark:text-white">
                {clusterName}
            </h1>
            <p class="text-lg text-slate-600 dark:text-slate-400 max-w-3xl">{clusterDescription}</p>
        </div>

        <div class="grid gap-6 sm:gap-8 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
            {posts.map((post) => {
                const trueSlug = post.slug.replace(/^[a-z]{2}\//, '');
                return (
                    <article class="group bg-[#F8FAFC] dark:bg-slate-800/50 rounded-2xl sm:rounded-3xl border border-transparent shadow-sm hover:bg-white dark:hover:bg-slate-700 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 h-full flex flex-col overflow-hidden">
                        <a href={getHref(`/blog/${trueSlug}/`)} class="block w-full aspect-[16/9] overflow-hidden bg-slate-100 dark:bg-slate-800 relative shrink-0">
                            {post.data.heroImage ? (
                                <Image
                                    src={post.data.heroImage as any}
                                    alt={post.data.title}
                                    class="w-full h-full object-contain group-hover:scale-[1.01] transition-transform duration-500"
                                    loading="lazy"
                                    width={1600}
                                    height={900}
                                    format="webp"
                                />
                            ) : (
                                <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-slate-100 to-slate-200 dark:from-slate-800 dark:to-slate-900">
                                    <span class="text-5xl opacity-50">📄</span>
                                </div>
                            )}
                        </a>
                        <div class="p-5 sm:p-8 flex-1 flex flex-col">
                            <h2 class="text-xl sm:text-2xl font-extrabold mb-2 sm:mb-4 line-clamp-2 text-slate-900 dark:text-white group-hover:text-[#405EDB] transition-colors leading-tight">
                                <a href={getHref(`/blog/${trueSlug}/`)}>{post.data.title}</a>
                            </h2>
                            <p class="text-slate-600 dark:text-slate-400 mb-4 sm:mb-8 line-clamp-3 flex-1 text-sm sm:text-base leading-relaxed">{post.data.description}</p>
                            <div class="pt-2 sm:pt-4 mt-auto">
                                <a href={getHref(`/blog/${trueSlug}/`)} class="inline-flex items-center px-4 sm:px-5 py-2 sm:py-2.5 rounded-xl bg-slate-100 dark:bg-slate-800 text-slate-900 dark:text-white font-bold text-xs sm:text-sm hover:bg-[#405EDB] hover:text-white transition-all duration-300">
                                    {t('btn.read_article')}
                                </a>
                            </div>
                        </div>
                    </article>
                );
            })}
        </div>
    </main>

    <Footer />
</Layout>

---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar';
import Footer from '../../../components/Footer.astro';
import { Image } from 'astro:assets';
import { ui } from '../../../i18n/ui';
import { useTranslations } from '../../../i18n/utils';
import { NON_DEFAULT_LOCALES } from '../../../i18n/locales';
import { getPhase1Text } from '../../../i18n/phase1-extra';
import {  BLOG_CLUSTERS, getClusterMeta, getPostCluster, ADJACENT_CLUSTERS  } from '../../../lib/blog-taxonomy';
import type { BlogClusterMeta } from '../../../lib/blog-taxonomy';

export function getStaticPaths() {
    return NON_DEFAULT_LOCALES.flatMap((lang) =>
        BLOG_CLUSTERS.map((cluster: (typeof BLOG_CLUSTERS)[number]) => ({ params: { lang, cluster: cluster.id } }))
    );
}

const localeParam = String(Astro.params.lang || 'en');
const locale = (Object.keys(ui).includes(localeParam) ? localeParam : 'en') as keyof typeof ui;
const localeCode = String(locale);
const t = useTranslations(locale);
const tx = (key: Parameters<typeof getPhase1Text>[1]) => getPhase1Text(localeCode, key);

const clusterId = String(Astro.params.cluster || '');
const clusterMeta = getClusterMeta(clusterId as any);
const clusterName = tx(`blog.cluster.${clusterMeta.id}` as any);
const clusterDescription = tx(`blog.cluster_desc.${clusterMeta.id}` as any);

const adjacentClusters = (ADJACENT_CLUSTERS[clusterMeta.id as keyof typeof ADJACENT_CLUSTERS] || [])
    .map(id => getClusterMeta(id as any));

const allPosts = await getCollection('blog');
const posts = allPosts
    .filter((post) => post.slug.startsWith(`${localeCode}/`) || (localeCode !== 'en' && post.slug.startsWith('en/')))
    .filter((post) => {
        const normalized = post.slug.replace(/^[a-z]{2}\//, '');
        const hasLocalizedVersion = allPosts.some((p) => p.slug === `${localeCode}/${normalized}`);
        if (post.slug.startsWith('en/') && localeCode !== 'en' && hasLocalizedVersion) return false;
        return true;
    })
    .filter((post) => getPostCluster(post) === clusterMeta.id)
    .sort((a, b) => {
        const aPillar = a.data.isPillar ? 1 : 0;
        const bPillar = b.data.isPillar ? 1 : 0;
        if (aPillar !== bPillar) return bPillar - aPillar;

        const aDate = a.data.updatedDate || a.data.pubDate;
        const bDate = b.data.updatedDate || b.data.pubDate;
        return bDate.valueOf() - aDate.valueOf();
    });

const getHref = (path: string) => (localeCode === 'en' ? path : `/${localeCode}${path === '/' ? '/' : path}`);
---

<Layout
    title={`${clusterName} | GetMediaTools Blog`}
    description={clusterDescription}
>
    <Navbar client:idle={{timeout: 3000}} currentPage="blog" lang={locale} />

    <main class="container mx-auto px-4 pt-6 md:pt-10 pb-12 md:pb-20 max-w-4xl">
        <!-- Breadcrumb -->
        <nav class="flex items-center text-[11px] font-bold tracking-widest uppercase font-sans text-slate-400 mb-12" aria-label="Breadcrumb">
            <a href={getHref("/")} class="hover:text-slate-900 dark:hover:text-white transition-colors shrink-0">{tx('blog.detail.home')}</a>
            <span class="mx-2 text-slate-300 dark:text-slate-600">/</span>
            <a href={getHref("/blog/")} class="hover:text-slate-900 dark:hover:text-white transition-colors shrink-0">{t('nav.blog')}</a>
            <span class="mx-2 text-slate-300 dark:text-slate-600">/</span>
            <span class="text-slate-900 dark:text-white">{clusterMeta.title}</span>
        </nav>

        <!-- Pillar Header -->
        <div class="mb-8 md:mb-10 border-b border-slate-100 dark:border-slate-800 pb-6 md:pb-8">
            <div class="flex flex-col md:flex-row items-center md:items-start gap-4 md:gap-5 mb-4 text-center md:text-left">
                <span class="text-4xl md:text-5xl shrink-0 mt-1">{clusterMeta.icon}</span>
                <div>
                    <h1 class="text-3xl md:text-4xl font-serif font-bold tracking-tight text-slate-900 dark:text-white mb-3">{clusterMeta.title}</h1>
                    <p class="text-[15px] sm:text-[17px] font-serif text-slate-600 dark:text-slate-400 max-w-2xl leading-relaxed">{clusterMeta.description}</p>
                </div>
            </div>
        </div>

        <!-- Article Feed -->
        {posts.length > 0 ? (
            <div class="max-w-3xl mx-auto space-y-2">
                {posts.map((post) => {
                    const trueSlug = post.slug.replace(/^[a-z]{2}\//, '');
                    return (
                        <article class="flex flex-col-reverse sm:flex-row gap-6 sm:gap-10 items-start group border-b border-slate-100 dark:border-slate-800 py-10 last:border-0 hover:bg-slate-50/50 dark:hover:bg-slate-900/30 px-4 sm:px-6 -mx-4 sm:-mx-6 rounded-2xl transition-colors">
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center gap-3 mb-3 text-sm text-slate-500 font-sans">
                                    <time datetime={post.data.pubDate.toISOString()} class="text-[13px] font-medium">
                                        {post.data.pubDate.toLocaleDateString('en', { month: 'short', day: 'numeric', year: 'numeric' })}
                                    </time>
                                </div>
                                
                                <h2 class="text-2xl sm:text-[28px] font-serif font-bold mb-3 text-slate-900 dark:text-white group-hover:text-[#405EDB] transition-colors leading-[1.25]">
                                    <a href={getHref(`/blog/${trueSlug}/`)}>
                                        {post.data.title}
                                    </a>
                                </h2>
                                
                                <p class="text-slate-600 dark:text-slate-400 line-clamp-3 font-serif text-[15px] sm:text-[17px] leading-relaxed mb-4">
                                    {post.data.description}
                                </p>
                                
                                <div class="flex items-center gap-2">
                                    <a href={getHref(`/blog/${trueSlug}/`)} class="text-[13px] font-bold text-slate-700 dark:text-slate-300 transition-colors uppercase tracking-wider font-sans group-hover:text-[#405EDB]">
                                        {t('btn.read_article')} <span class="ml-1">&rarr;</span>
                                    </a>
                                </div>
                            </div>

                            {post.data.heroImage && (
                                <a href={getHref(`/blog/${trueSlug}/`)} class="w-full sm:w-[260px] shrink-0 aspect-[16/9] rounded-xl overflow-hidden bg-slate-100 dark:bg-slate-800 relative shadow-sm border border-slate-100 dark:border-slate-800">
                                    <Image
                                        src={post.data.heroImage as any}
                                        alt={post.data.title}
                                        class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500"
                                        loading="lazy"
                                        width={640}
                                        height={360}
                                        format="webp"
                                    />
                                </a>
                            )}
                        </article>
                    );
                })}
            </div>
        ) : (
            <div class="text-center py-16">
                <span class="text-6xl mb-6 block opacity-30">📝</span>
                <p class="text-xl font-serif font-bold text-slate-400 dark:text-slate-500 mb-2">{tx('blog.detail.coming_soon_title')}</p>
                <p class="font-serif text-slate-500 dark:text-slate-600">{tx('blog.detail.coming_soon_desc')}</p>
            </div>
        )}

        <!-- Related Topics Section -->
        {adjacentClusters.length > 0 && (
            <div class="mt-12 md:mt-16 pt-8 md:pt-12 border-t border-slate-100 dark:border-slate-800 max-w-3xl mx-auto">
                <h2 class="text-xl md:text-2xl font-serif font-bold mb-6 md:mb-8 text-slate-900 dark:text-white">{tx('blog.detail.related_posts')}</h2>
                <div class="grid gap-4 sm:gap-6 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
                    {adjacentClusters.map((adj) => (
                        <a href={getHref(`/blog/${adj.id}/`)} class="group p-5 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900 hover:border-[#405EDB] dark:hover:border-[#405EDB] transition-colors duration-300">
                            <span class="text-3xl block mb-4">{adj.icon}</span>
                            <h3 class="font-sans font-bold text-[11px] uppercase tracking-widest text-slate-900 dark:text-white group-hover:text-[#405EDB] transition-colors mb-2">{adj.title}</h3>
                            <p class="font-serif text-[14px] text-slate-600 dark:text-slate-400 line-clamp-2">{adj.description}</p>
                        </a>
                    ))}
                </div>
            </div>
        )}
    </main>

    <Footer />
</Layout>

---
import Layout from '../layouts/Layout.astro';
import Navbar from './Navbar';
import Footer from './Footer.astro';
import { getLocalizedHref } from '../i18n/href';
import { languages, type ui } from '../i18n/ui';

interface Props {
    lang: keyof typeof ui;
}

const { lang } = Astro.props;

const pageTitle = lang === 'en'
    ? 'Instagram Downloader | Temporary Maintenance'
    : `Instagram Downloader (${languages[lang]}) | Temporary Maintenance`;
const description = 'Our Instagram downloader is temporarily unavailable while backend upgrades are in progress.';
const getHref = (path: string) => getLocalizedHref(path, lang);

const jsonLd = {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Instagram Downloader (Temporary)",
    "description": description,
    "url": `https://getmediatools.com${getHref('/instagram-downloader/')}`,
    "isPartOf": { "@type": "WebSite", "name": "MediaTools", "url": "https://getmediatools.com" }
};
---

<Layout
    title={pageTitle}
    description={description}
    robots="noindex, follow"
    jsonLd={jsonLd}
>
    <Navbar client:idle currentPage="home" lang={lang} />

    <main class="container mx-auto px-4 pt-10 pb-16 max-w-3xl">
        <div class="text-center mb-10">
            <div class="inline-flex items-center rounded-full px-3 py-1 text-sm font-medium bg-pink-100 text-pink-900 mb-4">
                Instagram
            </div>
            <h1 class="text-4xl font-bold tracking-tight mb-4">Instagram Downloader Is Temporarily Unavailable</h1>
            <p class="text-muted-foreground max-w-2xl mx-auto">
                We are upgrading backend reliability for this tool. Please use the related guides and other downloaders below while we complete maintenance.
            </p>
        </div>

        <div class="rounded-xl border bg-card p-6 mb-8">
            <h2 class="text-xl font-semibold mb-2">What you can use right now</h2>
            <ul class="space-y-2 text-sm text-muted-foreground">
                <li><a class="text-primary hover:underline" href={getHref('/blog/download-instagram-reels-without-watermark/')}>Instagram Reels guide</a> with practical save methods.</li>
                <li><a class="text-primary hover:underline" href={getHref('/facebook-downloader/')}>Facebook Downloader</a> for reels and public video posts.</li>
                <li><a class="text-primary hover:underline" href={getHref('/tiktok-downloader/')}>TikTok Downloader</a> for watermark-free TikTok video downloads.</li>
            </ul>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
            <a href={getHref('/blog/')} class="group p-4 rounded-xl border bg-card hover:border-primary/50 hover:shadow-md transition-all">
                <h3 class="font-semibold group-hover:text-primary transition-colors">Browse Blog Guides</h3>
                <p class="text-sm text-muted-foreground mt-1">Find localized step-by-step download tutorials.</p>
            </a>
            <a href={getHref('/')} class="group p-4 rounded-xl border bg-card hover:border-primary/50 hover:shadow-md transition-all">
                <h3 class="font-semibold group-hover:text-primary transition-colors">Back to All Tools</h3>
                <p class="text-sm text-muted-foreground mt-1">Use the currently available download and conversion tools.</p>
            </a>
        </div>
    </main>

    <Footer />
</Layout>

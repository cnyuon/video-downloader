---
import { languages } from '../../i18n/ui';
import { getCollection } from 'astro:content';

// This is the path WITHOUT the language prefix
// e.g., if we are on /es/tiktok-downloader, this returns /tiktok-downloader
// if we are on /tiktok-downloader, this returns /tiktok-downloader
const currentUrl = new URL(Astro.request.url);
const pathSegments = currentUrl.pathname.split('/').filter(Boolean);

let cleanPath = currentUrl.pathname;
if (pathSegments.length > 0 && Object.keys(languages).includes(pathSegments[0])) {
    cleanPath = '/' + pathSegments.slice(1).join('/');
}

// Enforce trailing slash
if (!cleanPath.endsWith('/')) {
    cleanPath += '/';
}

// Determine which locales actually have content for this page.
// For blog posts, only emit hreflang for locales with a matching translation.
// For all other pages (homepage, blog index, cluster pages), emit all locales.
const NON_DEFAULT_LOCALES = Object.keys(languages).filter(l => l !== 'en');
let availableLocales: string[] = Object.keys(languages);

const blogPostMatch = /^\/blog\/([^/]+)\/$/.exec(cleanPath);
if (blogPostMatch) {
    const postSlug = blogPostMatch[1];
    // Check if this slug is a cluster page (not a blog post)
    const { BLOG_CLUSTERS } = await import('../../lib/blog-taxonomy');
    const clusterIds = new Set(BLOG_CLUSTERS.map((c: any) => c.id));

    if (!clusterIds.has(postSlug)) {
        // This is a blog post — check which locales have a translation
        const allPosts = await getCollection('blog');
        const postBySlug = new Map(allPosts.map(post => [post.slug, post])) as Map<string, any>;

        availableLocales = ['en']; // English always available
        for (const locale of NON_DEFAULT_LOCALES) {
            if (postBySlug.has(`${locale}/${postSlug}`)) {
                availableLocales.push(locale);
            }
        }
    }
}
---

<!-- X-Default (Fallback for unidentified languages) -->
<link rel="alternate" hreflang="x-default" href={`https://getmediatools.com${cleanPath}`} />

<!-- Exact language mappings — only for locales that have actual content -->
{availableLocales.map((code) => {
    // If cleanPath is '/' and code is 'es', we want '/es/'
    // If cleanPath is '/tiktok-downloader/' and code is 'es', we want '/es/tiktok-downloader/'
    const finalPath = code === 'en' ? cleanPath : `/${code}${cleanPath === '/' ? '' : cleanPath}`;
    const cleanFinalPath = finalPath.endsWith('/') ? finalPath : finalPath + '/';
    return (
        <link 
            rel="alternate" 
            hreflang={code} 
            href={`https://getmediatools.com${cleanFinalPath}`} 
        />
    );
})}

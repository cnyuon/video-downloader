---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Navbar from './Navbar';
import Footer from './Footer.astro';
import { useTranslations } from '../i18n/utils';
import { getLocalizedHref } from '../i18n/href';
import { BLOG_CLUSTERS, getPostCluster } from '../lib/blog-taxonomy';
import { getPhase1Text } from '../i18n/phase1-extra';
import type { ui } from '../i18n/ui';

interface Props {
    lang: keyof typeof ui;
}

const { lang } = Astro.props as Props;
const t = useTranslations(lang);
const localeCode = String(lang);
const tx = (key: Parameters<typeof getPhase1Text>[1]) => getPhase1Text(localeCode, key);
const allBlogPosts = await getCollection('blog');

const baselinePosts = allBlogPosts.filter((post) => post.slug.startsWith('en/'));
const sortedBaseline = baselinePosts.sort((a, b) => (b.data.updatedDate || b.data.pubDate).valueOf() - (a.data.updatedDate || a.data.pubDate).valueOf());

const localizedPosts = sortedBaseline
    .map((enPost) => {
        const trueSlug = enPost.slug.replace('en/', '');
        if (localeCode === 'en') {
            return { ...enPost, slug: trueSlug };
        }
        const nativePost = allBlogPosts.find((p) => p.slug === `${localeCode}/${trueSlug}`);
        // Only include posts that have actual translations for this locale
        if (!nativePost) return null;
        return {
            ...nativePost,
            slug: trueSlug,
        };
    })
    .filter((post): post is NonNullable<typeof post> => post !== null);

const getHref = (path: string) => getLocalizedHref(path, lang);

const jsonLd = {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: t('blog.title'),
    description: t('blog.desc'),
    url: `https://getmediatools.com${getHref('/blog/')}`,
    isPartOf: { '@type': 'WebSite', name: 'GetMediaTools', url: 'https://getmediatools.com' },
    publisher: { '@type': 'Organization', name: 'GetMediaTools' },
};
---

<Layout title={`${t('blog.title')} | GetMediaTools`} description={t('blog.desc')} jsonLd={jsonLd}>
    <Navbar client:idle currentPage="blog" lang={lang} />

    <main class="container mx-auto px-4 pt-8 md:pt-12 pb-12 md:pb-20 max-w-4xl">
        <div class="text-center mb-10 md:mb-16 border-b border-slate-100 dark:border-slate-800 pb-8 md:pb-12">
            <h1 class="text-3xl md:text-5xl font-serif font-bold tracking-normal mb-4 md:mb-5 text-slate-900 dark:text-white leading-[1.1]">
                {t('blog.title')}
            </h1>
            <p class="text-[15px] sm:text-lg text-slate-700 dark:text-slate-300 max-w-2xl mx-auto leading-relaxed font-serif px-2">
                {t('blog.desc')}
            </p>
        </div>

        <div class="mb-10 md:mb-16 border-b border-slate-100 dark:border-slate-800 pb-8 md:pb-12">
            <p class="text-[11px] font-bold uppercase tracking-[0.2em] text-[#405EDB] mb-6 font-sans">{tx('blog.cluster.pick')}</p>
            <div class="flex flex-wrap gap-3">
                {BLOG_CLUSTERS.filter(c => c.id !== 'general').map((cluster) => {
                    const clusterPostCount = localizedPosts.filter(p => getPostCluster(p) === cluster.id).length;
                    return (
                        <a
                            href={getHref(`/blog/${cluster.id}/`)}
                            class="inline-flex items-center gap-2 px-3 py-2 border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 hover:border-[#405EDB] dark:hover:border-[#405EDB] hover:text-[#405EDB] transition-colors"
                        >
                            <span class="text-base leading-none">{(cluster as any).icon || '📚'}</span>
                            <span class="font-sans font-bold text-[11px] uppercase tracking-widest whitespace-nowrap">{tx(`blog.cluster.${cluster.id}` as any)}</span>
                            {clusterPostCount > 0 && (
                                <span class="ml-1 text-[10px] text-slate-400 dark:text-slate-500 font-sans">
                                    ({clusterPostCount})
                                </span>
                            )}
                        </a>
                    );
                })}
            </div>
        </div>

        <div class="max-w-3xl mx-auto space-y-2">
            {localizedPosts.map((post) => (
                <article class="flex flex-col-reverse sm:flex-row gap-6 sm:gap-10 items-start group border-b border-slate-100 dark:border-slate-800 py-10 last:border-0 hover:bg-slate-50/50 dark:hover:bg-slate-900/30 px-4 sm:px-6 -mx-4 sm:-mx-6 rounded-2xl transition-colors">
                    <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-3 mb-3 text-sm text-slate-600 font-sans">
                            <span class="font-bold uppercase tracking-wider text-[#405EDB] text-[11px] bg-[#405EDB]/10 px-2 py-0.5 rounded-sm">{tx(`blog.cluster.${getPostCluster(post)}` as any)}</span>
                            <span class="text-slate-400">&bull;</span>
                            <time datetime={post.data.pubDate.toISOString()} class="text-[13px] font-medium">
                                {post.data.pubDate.toLocaleDateString(localeCode, { month: 'short', day: 'numeric', year: 'numeric' })}
                            </time>
                        </div>
                        
                        <h2 class="text-2xl sm:text-[28px] font-serif font-bold mb-3 text-slate-900 dark:text-white group-hover:text-[#405EDB] transition-colors leading-[1.25]">
                            <a href={getHref(`/blog/${post.slug}/`)}>
                                {post.data.title}
                            </a>
                        </h2>
                        
                        <p class="text-slate-700 dark:text-slate-300 line-clamp-3 font-serif text-[15px] sm:text-[17px] leading-relaxed mb-4">
                            {post.data.description}
                        </p>
                        
                        <div class="flex items-center gap-2">
                            <a href={getHref(`/blog/${post.slug}/`)} class="text-[13px] font-bold text-slate-700 dark:text-slate-300 hover:text-[#405EDB] transition-colors uppercase tracking-wider font-sans group-hover:text-[#405EDB]">
                                {t('btn.read_article')} <span class="ml-1">&rarr;</span>
                            </a>
                        </div>
                    </div>

                    {post.data.heroImage && (
                        <a href={getHref(`/blog/${post.slug}/`)} class="w-full sm:w-[260px] shrink-0 aspect-[16/9] rounded-xl overflow-hidden bg-slate-100 dark:bg-slate-800 relative shadow-sm border border-slate-100 dark:border-slate-800">
                            <Image
                                src={post.data.heroImage as any}
                                alt={post.data.title}
                                class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500"
                                loading="lazy"
                                width={640}
                                height={360}
                                format="webp"
                            />
                        </a>
                    )}
                </article>
            ))}
        </div>
    </main>

    <Footer />
</Layout>

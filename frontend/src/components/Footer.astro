---
/**
 * Footer - Site-wide footer with featured badges.
 * Used on every page for consistent branding.
 */
import { getLangFromUrl } from '../i18n/utils';
import { getLocalizedHref } from '../i18n/href';

const lang = getLangFromUrl(Astro.url);
const getHref = (path: string) => getLocalizedHref(path, lang);

const BADGE_PLACEHOLDER = 'data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///ywAAAAAAQABAAACAUwAOw==';
---

<footer class="mt-32 py-10 border-t border-slate-200 dark:border-slate-800">
    <div class="container mx-auto px-4 max-w-5xl">
        <div class="flex flex-col sm:flex-row justify-between items-center gap-6 text-[13px] font-medium text-slate-600 dark:text-slate-300 font-sans tracking-wide">
            <div>
                © {new Date().getFullYear()} GetMediaTools
            </div>
            
            <div class="flex flex-wrap items-center gap-3 sm:gap-5 uppercase">
                <a href={getHref('/')} class="hover:text-slate-900 dark:hover:text-white transition-colors">Home</a>
                <span>&middot;</span>
                <a href={getHref('/blog/')} class="hover:text-slate-900 dark:hover:text-white transition-colors">Blog</a>
            </div>
        </div>


        <!-- Featured Badges -->
        <div class="py-12 overflow-hidden relative w-full group">
            <div class="flex flex-wrap items-center justify-center gap-8 px-4 opacity-40 hover:opacity-100 transition-opacity duration-500 grayscale hover:grayscale-0">
                <a href="https://fazier.com/launches/getmediatools.com" target="_blank" rel="nofollow noopener noreferrer" class="hover:scale-105 transition-transform duration-300">
                    <img loading="lazy" decoding="async" fetchpriority="low" src={BADGE_PLACEHOLDER} data-src="https://fazier.com/api/v1//public/badges/launch_badges.svg?badge_type=featured&theme=light" data-defer-badge width="250" height="54" alt="Fazier badge" class="h-[36px] w-auto drop-shadow-sm" />
                </a>
                <a href="https://twelve.tools" target="_blank" rel="nofollow noopener noreferrer" class="hover:scale-105 transition-transform duration-300">
                    <img loading="lazy" decoding="async" fetchpriority="low" src={BADGE_PLACEHOLDER} data-src="https://twelve.tools/badge0-light.svg" data-defer-badge alt="Featured on Twelve Tools" width="200" height="54" class="h-[36px] w-auto drop-shadow-sm" />
                </a>
                <a href="https://wired.business" target="_blank" rel="nofollow noopener noreferrer" class="hover:scale-105 transition-transform duration-300">
                    <img loading="lazy" decoding="async" fetchpriority="low" src={BADGE_PLACEHOLDER} data-src="https://wired.business/badge0-light.svg" data-defer-badge alt="Featured on Wired Business" width="200" height="54" class="h-[36px] w-auto drop-shadow-sm" />
                </a>
                <a href="https://saastool.site/item/getmediatools" target="_blank" rel="nofollow noopener noreferrer" class="hover:scale-105 transition-transform duration-300">
                    <img loading="lazy" decoding="async" fetchpriority="low" src={BADGE_PLACEHOLDER} data-src="https://saastool.site/badges/saastool-light.svg" data-defer-badge alt="Featured on SaaSTool.site" height="54" width="auto" class="h-[36px] w-auto drop-shadow-sm" />
                </a>
                <a href="https://turbo0.com/item/getmediatools" target="_blank" rel="nofollow noopener noreferrer" class="hover:scale-105 transition-transform duration-300">
                    <img loading="lazy" decoding="async" fetchpriority="low" src={BADGE_PLACEHOLDER} data-src="https://img.turbo0.com/badge-listed-light.svg" data-defer-badge alt="Listed on Turbo0" class="h-[36px] w-auto drop-shadow-sm" />
                </a>
                <a href="https://findly.tools/getmediatools?utm_source=getmediatools" target="_blank" rel="nofollow noopener noreferrer" class="hover:scale-105 transition-transform duration-300">
                    <img loading="lazy" decoding="async" fetchpriority="low" src={BADGE_PLACEHOLDER} data-src="https://findly.tools/badges/findly-tools-badge-light.svg" data-defer-badge alt="Featured on Findly.tools" width="175" height="55" class="h-[36px] w-auto drop-shadow-sm" />
                </a>
                <a href="https://launchigniter.com/product/getmediatools?ref=badge-getmediatools" target="_blank" rel="nofollow noopener noreferrer" class="hover:scale-105 transition-transform duration-300">
                    <img loading="lazy" decoding="async" fetchpriority="low" src={BADGE_PLACEHOLDER} data-src="https://launchigniter.com/api/badge/getmediatools?theme=light" data-defer-badge alt="Featured on LaunchIgniter" width="212" height="55" class="h-[36px] w-auto drop-shadow-sm" />
                </a>
            </div>
        </div>
    </div>
</footer>

<script is:inline>
    (() => {
        const badgeImages = Array.from(document.querySelectorAll('img[data-defer-badge]'));
        if (badgeImages.length === 0) return;

        let loaded = false;
        const loadBadges = () => {
            if (loaded) return;
            loaded = true;
            badgeImages.forEach((img) => {
                const src = img.getAttribute('data-src');
                if (src) img.setAttribute('src', src);
            });
            window.removeEventListener('scroll', onTrigger);
            window.removeEventListener('pointerdown', onTrigger);
            window.removeEventListener('keydown', onTrigger);
        };

        const onTrigger = () => {
            if ('requestIdleCallback' in window) {
                window.requestIdleCallback(loadBadges, { timeout: 2000 });
                return;
            }
            window.setTimeout(loadBadges, 500);
        };

        window.addEventListener('scroll', onTrigger, { once: true, passive: true });
        window.addEventListener('pointerdown', onTrigger, { once: true, passive: true });
        window.addEventListener('keydown', onTrigger, { once: true });
    })();
</script>

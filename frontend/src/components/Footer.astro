---
/**
 * Footer - Site-wide footer with tool links, blog, and legal
 * Used on every page for consistent internal linking and crawlability
 */
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { getLocalizedHref } from '../i18n/href';
import { languages } from '../i18n/ui';
import { getCollection } from 'astro:content';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const pathname = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
const localePrefix = lang === 'en' ? '' : `/${lang}`;
const pathWithoutLocale = localePrefix && pathname.startsWith(localePrefix)
    ? pathname.slice(localePrefix.length) || '/'
    : pathname;
const isBlogPostPage = pathWithoutLocale.startsWith('/blog/') && pathWithoutLocale !== '/blog/';
const currentBlogSlug = isBlogPostPage
    ? pathWithoutLocale.replace(/^\/blog\/|\/$/g, '')
    : null;

// Fetch recently updated blog posts for the current language
const posts = await getCollection('blog', ({ id }) => {
    return id.startsWith(`${lang}/`);
});

const recentPosts = posts
    .sort((a, b) => {
        const aDate = a.data.updatedDate || a.data.pubDate;
        const bDate = b.data.updatedDate || b.data.pubDate;
        return bDate.valueOf() - aDate.valueOf();
    })
    .filter((post) => {
        if (!currentBlogSlug) return true;
        const localizedSlug = post.slug.replace(/^[a-z]{2}\//, '');
        return localizedSlug !== currentBlogSlug;
    })
    .slice(0, 3);

const getHref = (path: string) => getLocalizedHref(path, lang);

const localeBlogLinks = Object.entries(languages).map(([code, label]) => ({
    code,
    label,
    href: code === 'en' ? '/blog/' : `/${code}/blog/`,
}));
---

<footer class="bg-[#F8FAFC] dark:bg-slate-900/50 py-16 md:py-24 mt-0 border-t border-slate-100 dark:border-slate-800/50">
    <div class="container mx-auto px-4 max-w-7xl">
        <div class="grid gap-12 md:grid-cols-4 mb-16">
            <!-- Brand -->
            <div class="md:col-span-2 md:pr-12">
                <a href={getHref('/')} class="flex items-center space-x-3 mb-6">
                    <div class="h-8 w-8 rounded-xl bg-gradient-to-br from-[#405EDB] to-blue-600 flex items-center justify-center shadow-md">
                        <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                        </svg>
                    </div>
                    <span class="font-extrabold text-xl tracking-tight text-slate-900 dark:text-white">GetMediaTools</span>
                </a>
                <p class="text-[15px] leading-loose text-slate-600 dark:text-slate-400 font-medium max-w-md">{t('footer.desc')}</p>
            </div>

            <!-- Tools -->
            <div>
                <h3 class="font-extrabold mb-6 text-sm uppercase tracking-widest text-[#405EDB]">{t('footer.tools')}</h3>
                <ul class="space-y-4 font-bold text-[15px] text-slate-600 dark:text-slate-400">
                    <li><a href={getHref('/tiktok-downloader/')} class="hover:text-slate-900 dark:hover:text-white transition-colors">{t('nav.tiktok')}</a></li>
                    <li><a href={getHref('/twitter-downloader/')} class="hover:text-slate-900 dark:hover:text-white transition-colors">{t('nav.twitter')}</a></li>
                    <li><a href={getHref('/facebook-downloader/')} class="hover:text-slate-900 dark:hover:text-white transition-colors">{t('nav.facebook')}</a></li>
                    <li><a href={getHref('/tiktok-sound-downloader/')} class="hover:text-slate-900 dark:hover:text-white transition-colors">{t('nav.sound')}</a></li>
                    <li><a href={getHref('/video-to-mp3/')} class="hover:text-slate-900 dark:hover:text-white transition-colors">{t('nav.audio')}</a></li>
                    <li><a href={getHref('/thumbnail-grabber/')} class="hover:text-slate-900 dark:hover:text-white transition-colors">{t('nav.thumbnail')}</a></li>
                </ul>
            </div>

            <!-- Resources -->
            <div>
                <h3 class="font-extrabold mb-6 text-sm uppercase tracking-widest text-[#405EDB]">{t('footer.resources')}</h3>
                <ul class="space-y-4 font-bold text-[15px] text-slate-600 dark:text-slate-400">
                    <li><a href={getHref('/blog/')} class="hover:text-slate-900 dark:hover:text-white transition-colors">{t('nav.blog')}</a></li>
                    {recentPosts.map(post => {
                        const slug = post.slug.replace(/^[a-z]{2}\//, '');
                        return (
                            <li>
                                <a href={getHref(`/blog/${slug}/`)} class="hover:text-slate-900 dark:hover:text-white transition-colors line-clamp-1" title={post.data.title}>
                                    {post.data.title}
                                </a>
                            </li>
                        );
                    })}
                </ul>
            </div>
        </div>

        <div class="border-t border-slate-200 dark:border-slate-800/50 pt-10 mb-12">
            <h3 class="font-extrabold mb-6 text-sm uppercase tracking-widest text-[#405EDB] text-center md:text-left">Language Hubs</h3>

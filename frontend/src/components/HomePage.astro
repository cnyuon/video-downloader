---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Navbar from './Navbar';
import Footer from './Footer.astro';
import { useTranslations } from '../i18n/utils';
import { getLocalizedHref } from '../i18n/href';
import { BLOG_CLUSTERS, getPostCluster } from '../lib/blog-taxonomy';
import { Image } from 'astro:assets';
import type { ui } from '../i18n/ui';

interface Props {
    lang: keyof typeof ui;
}

const { lang } = Astro.props as Props;
const t = useTranslations(lang);
const localeCode = String(lang);
const getHref = (path: string) => getLocalizedHref(path, lang);

const allPosts = await getCollection('blog');
const localizedPosts = allPosts.filter((post) => post.slug.startsWith(`${localeCode}/`));
const fallbackPosts = allPosts.filter((post) => post.slug.startsWith('en/'));
const sortedPosts = (localizedPosts.length > 0 ? localizedPosts : fallbackPosts)
    .sort((a, b) => (b.data.updatedDate || b.data.pubDate).valueOf() - (a.data.updatedDate || a.data.pubDate).valueOf());

const featuredPosts = sortedPosts.slice(0, 6).map((post) => ({
    slug: post.slug.replace(/^[a-z]{2}\//, ''),
    title: post.data.title,
    description: post.data.description,
    heroImage: post.data.heroImage,
    pubDate: post.data.updatedDate || post.data.pubDate,
    cluster: getPostCluster(post),
}));

const jsonLd = {
    '@context': 'https://schema.org',
    '@graph': [
        {
            '@type': 'WebSite',
            name: 'GetMediaTools',
            url: 'https://getmediatools.com',
            description: t('index.meta.desc'),
        },
        {
            '@type': 'Organization',
            name: 'GetMediaTools',
            url: 'https://getmediatools.com',
            logo: 'https://getmediatools.com/icon-512.png',
            description: t('index.meta.desc'),
            sameAs: [],
        },
    ],
};

const clusterMeta = BLOG_CLUSTERS.find((c) => c.id !== 'general');
---

<Layout title={t('index.meta.title')} description={t('index.meta.desc')} jsonLd={jsonLd}>
    <Navbar client:idle currentPage="home" lang={lang} />

    <div class="w-full bg-[#1A1A2E] text-white pt-24 pb-32 px-4 relative overflow-hidden">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-3xl h-64 bg-[#405EDB] rounded-full mix-blend-screen filter blur-[100px] opacity-20"></div>

        <div class="container mx-auto max-w-4xl text-center relative z-10">
            <div class="mb-8">
                <span class="inline-block bg-[#405EDB]/20 text-[#8DA0FF] border border-[#405EDB]/30 text-xs font-bold px-4 py-1.5 rounded-full uppercase tracking-wider backdrop-blur-sm">
                    {t('blog.title')}
                </span>
            </div>
            <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight mb-8 leading-[1.1] text-white">
                {t('index.hero.title')} <br class="hidden sm:block" />
                <span class="text-[#405EDB]">{t('index.hero.highlight')}</span>
            </h1>
            <p class="text-lg md:text-xl text-gray-300 max-w-2xl mx-auto leading-relaxed">
                {t('index.hero.desc')}
            </p>
            <div class="mt-10 flex flex-wrap gap-4 justify-center">
                <a href={getHref('/blog/')} class="inline-flex items-center px-8 py-3.5 rounded-full bg-[#405EDB] text-white font-bold text-sm hover:bg-[#3249B8] transition-colors shadow-lg shadow-[#405EDB]/25">
                    Browse Articles
                    <svg class="w-4 h-4 ml-2 rtl:rotate-180" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
                </a>
            </div>
        </div>
    </div>

    <main class="container mx-auto px-4 -mt-16 pb-24 relative z-20">
        <!-- Featured Articles Grid -->
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 max-w-5xl mx-auto">
            {featuredPosts.map((post, i) => (
                <a href={getHref(`/blog/${post.slug}/`)} class="group block rounded-2xl bg-[#F4F7FB] dark:bg-slate-800 border border-transparent hover:bg-white dark:hover:bg-slate-700 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 overflow-hidden">
                    <div class="w-full aspect-[16/9] overflow-hidden bg-slate-100 dark:bg-slate-800 relative shrink-0">
                        {post.heroImage ? (
                            <Image
                                src={post.heroImage as any}
                                alt={post.title}
                                class="w-full h-full object-contain group-hover:scale-[1.02] transition-transform duration-500"
                                loading={i < 3 ? 'eager' : 'lazy'}
                                width={800}
                                height={450}
                                format="webp"
                            />
                        ) : (
                            <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-slate-100 to-slate-200 dark:from-slate-800 dark:to-slate-900">
                                <span class="text-5xl opacity-50">📝</span>
                            </div>
                        )}
                    </div>
                    <div class="p-6">
                        <span class="inline-block text-xs font-bold px-3 py-1 rounded-full bg-[#405EDB]/10 text-[#405EDB] dark:bg-[#405EDB]/20 dark:text-[#8DA0FF] mb-3 uppercase tracking-wider">
                            {BLOG_CLUSTERS.find(c => c.id === post.cluster)?.title || 'Guide'}
                        </span>
                        <h2 class="font-bold text-lg mb-2 text-slate-900 dark:text-white group-hover:text-[#405EDB] transition-colors line-clamp-2">{post.title}</h2>
                        <p class="text-[14px] text-slate-600 dark:text-slate-400 leading-relaxed line-clamp-2">{post.description}</p>
                    </div>
                </a>
            ))}
        </div>

        <!-- Topic Clusters Section -->
        <div class="mt-32 max-w-5xl mx-auto">
            <h2 class="text-3xl font-extrabold text-center mb-4 text-slate-900 dark:text-white">Explore by Topic</h2>
            <p class="text-center text-slate-600 dark:text-slate-400 mb-12 max-w-2xl mx-auto">Dive deep into expert guides organized by action and strategy.</p>
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
                {BLOG_CLUSTERS.filter(c => c.id !== 'general').map((cluster) => (
                    <a href={getHref(`/blog/${cluster.id}/`)} class="group p-6 rounded-2xl bg-[#F4F7FB] dark:bg-slate-800 border border-transparent hover:bg-white dark:hover:bg-slate-700 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                        <span class="text-3xl block mb-3">{cluster.icon}</span>
                        <h3 class="font-bold text-lg mb-2 text-slate-900 dark:text-white group-hover:text-[#405EDB] transition-colors">{cluster.title}</h3>
                        <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed line-clamp-2">{cluster.description}</p>
                    </a>
                ))}
            </div>
        </div>

        <!-- Why Section (repurposed) -->
        <div class="mt-32 max-w-5xl mx-auto">
            <h2 class="text-3xl font-extrabold text-center mb-12 text-slate-900 dark:text-white">{t('index.why.title')}</h2>
            <div class="grid gap-8 md:grid-cols-3">
                <div class="text-center p-6 border-none bg-transparent">
                    <div class="w-16 h-16 rounded-2xl bg-[#405EDB]/10 dark:bg-[#405EDB]/20 flex items-center justify-center mx-auto mb-6 transform hover:scale-110 transition-transform">
                        <span class="text-3xl">📚</span>
                    </div>
                    <h3 class="font-bold text-xl mb-3 text-slate-900 dark:text-white">{t('index.why.1.title')}</h3>
                    <p class="text-[16px] text-slate-600 dark:text-slate-400 leading-relaxed">{t('index.why.1.desc')}</p>
                </div>
                <div class="text-center p-6 border-none bg-transparent">
                    <div class="w-16 h-16 rounded-2xl bg-[#405EDB]/10 dark:bg-[#405EDB]/20 flex items-center justify-center mx-auto mb-6 transform hover:scale-110 transition-transform">
                        <span class="text-3xl">🔒</span>
                    </div>
                    <h3 class="font-bold text-xl mb-3 text-slate-900 dark:text-white">{t('index.why.2.title')}</h3>
                    <p class="text-[16px] text-slate-600 dark:text-slate-400 leading-relaxed">{t('index.why.2.desc')}</p>
                </div>
                <div class="text-center p-6 border-none bg-transparent">
                    <div class="w-16 h-16 rounded-2xl bg-[#405EDB]/10 dark:bg-[#405EDB]/20 flex items-center justify-center mx-auto mb-6 transform hover:scale-110 transition-transform">
                        <span class="text-3xl">⚡</span>
                    </div>
                    <h3 class="font-bold text-xl mb-3 text-slate-900 dark:text-white">{t('index.why.3.title')}</h3>
                    <p class="text-[16px] text-slate-600 dark:text-slate-400 leading-relaxed">{t('index.why.3.desc')}</p>
                </div>
            </div>
        </div>
    </main>

    <Footer />
</Layout>

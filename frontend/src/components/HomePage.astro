---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Navbar from './Navbar';
import Footer from './Footer.astro';
import { useTranslations } from '../i18n/utils';
import { getLocalizedHref } from '../i18n/href';
import { BLOG_CLUSTERS, getPostCluster } from '../lib/blog-taxonomy';
import { Image } from 'astro:assets';
import type { ui } from '../i18n/ui';

interface Props {
    lang: keyof typeof ui;
}

const { lang } = Astro.props as Props;
const t = useTranslations(lang);
const localeCode = String(lang);
const getHref = (path: string) => getLocalizedHref(path, lang);

const allPosts = await getCollection('blog');
const localizedPosts = allPosts.filter((post) => post.slug.startsWith(`${localeCode}/`));
const fallbackPosts = allPosts.filter((post) => post.slug.startsWith('en/'));
const sortedPosts = (localizedPosts.length > 0 ? localizedPosts : fallbackPosts)
    .sort((a, b) => (b.data.updatedDate || b.data.pubDate).valueOf() - (a.data.updatedDate || a.data.pubDate).valueOf());

const featuredPosts = sortedPosts.slice(0, 6).map((post) => ({
    slug: post.slug.replace(/^[a-z]{2}\//, ''),
    title: post.data.title,
    description: post.data.description,
    heroImage: post.data.heroImage,
    pubDate: post.data.updatedDate || post.data.pubDate,
    cluster: getPostCluster(post),
}));

const jsonLd = {
    '@context': 'https://schema.org',
    '@graph': [
        {
            '@type': 'WebSite',
            name: 'GetMediaTools',
            alternateName: 'MediaTools',
            url: 'https://getmediatools.com/',
            description: t('index.meta.desc'),
        },
        {
            '@type': 'Organization',
            name: 'GetMediaTools',
            url: 'https://getmediatools.com/',
            logo: 'https://getmediatools.com/logo.png',
            description: t('index.meta.desc'),
            sameAs: [],
        },
    ],
};

const clusterMeta = BLOG_CLUSTERS.find((c) => c.id !== 'general');
---

<Layout title={t('index.meta.title')} description={t('index.meta.desc')} jsonLd={jsonLd}>
    <Navbar client:idle currentPage="home" lang={lang} />

    <div class="w-full bg-white dark:bg-slate-950 pt-16 pb-12 md:pt-20 md:pb-16 px-4 border-b border-slate-100 dark:border-slate-800/80">
        <div class="container mx-auto max-w-4xl text-center">
            <div class="mb-8">
                <span class="inline-block text-slate-500 text-[11px] font-extrabold px-3 py-1 uppercase tracking-[0.2em] font-sans">
                    {t('blog.title')}
                </span>
            </div>
            <h1 class="text-4xl md:text-6xl lg:text-7xl font-serif font-bold tracking-tight mb-8 leading-[1.1] text-slate-900 dark:text-white">
                {t('index.hero.title')} <br class="hidden sm:block" />
                <span class="text-[#405EDB]">{t('index.hero.highlight')}</span>
            </h1>
            <p class="text-lg md:text-xl text-slate-600 dark:text-slate-400 max-w-2xl mx-auto leading-relaxed font-serif">
                {t('index.hero.desc')}
            </p>
            <div class="mt-12 flex flex-wrap gap-4 justify-center">
                <a href={getHref('/blog/')} class="inline-flex items-center px-6 py-3 border border-slate-900 dark:border-white text-slate-900 dark:text-white font-bold text-[13px] hover:bg-slate-900 hover:text-white dark:hover:bg-white dark:hover:text-slate-900 transition-colors uppercase tracking-widest font-sans">
                    Browse Articles
                </a>
            </div>
        </div>
    </div>

    <main class="container mx-auto px-4 pt-12 pb-16 md:pt-16 md:pb-20 relative z-20">
        <!-- Featured Articles Grid -->
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 max-w-5xl mx-auto">
            {featuredPosts.map((post, i) => (
                <a href={getHref(`/blog/${post.slug}/`)} class="group flex flex-col border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 hover:border-slate-400 dark:hover:border-slate-600 transition-colors duration-300">
                    <div class="w-full aspect-[16/9] overflow-hidden bg-slate-50 dark:bg-slate-900/50 border-b border-slate-100 dark:border-slate-800">
                        {post.heroImage ? (
                            <Image
                                src={post.heroImage as any}
                                alt={post.title}
                                class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500"
                                loading={i < 3 ? 'eager' : 'lazy'}
                                width={800}
                                height={450}
                                format="webp"
                            />
                        ) : (
                            <div class="w-full h-full flex items-center justify-center bg-slate-50 dark:bg-slate-900/50">
                                <span class="text-3xl opacity-20">📝</span>
                            </div>
                        )}
                    </div>
                    <div class="p-6 flex flex-col flex-grow">
                        <span class="text-[10px] font-extrabold text-[#405EDB] mb-4 uppercase tracking-[0.15em] font-sans">
                            {BLOG_CLUSTERS.find(c => c.id === post.cluster)?.title || 'Guide'}
                        </span>
                        <h2 class="font-serif font-bold text-xl mb-3 text-slate-900 dark:text-white group-hover:text-[#405EDB] transition-colors leading-[1.3]">{post.title}</h2>
                        <p class="text-[15px] font-serif text-slate-600 dark:text-slate-400 leading-relaxed line-clamp-2 mt-auto">{post.description}</p>
                    </div>
                </a>
            ))}
        </div>

        <!-- Topic Clusters Section -->
        <div class="mt-20 pt-10 border-t border-slate-100 dark:border-slate-800 max-w-5xl mx-auto">
            <h2 class="text-3xl font-serif font-bold text-center mb-4 text-slate-900 dark:text-white">Explore by Topic</h2>
            <p class="text-center font-serif text-slate-600 dark:text-slate-400 mb-12 max-w-2xl mx-auto">Dive deep into expert guides organized by action and strategy.</p>
            <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
                {BLOG_CLUSTERS.filter(c => c.id !== 'general').map((cluster) => (
                    <a href={getHref(`/blog/${cluster.id}/`)} class="group p-6 border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900 hover:border-slate-400 dark:hover:border-slate-600 transition-colors duration-300">
                        <span class="text-3xl block mb-4">{cluster.icon}</span>
                        <h3 class="font-sans font-bold text-[13px] uppercase tracking-widest mb-3 text-slate-900 dark:text-white group-hover:text-[#405EDB] transition-colors">{cluster.title}</h3>
                        <p class="font-serif text-[14px] text-slate-600 dark:text-slate-400 leading-relaxed line-clamp-3">{cluster.description}</p>
                    </a>
                ))}
            </div>
        </div>


    </main>

    <Footer />
</Layout>
